0002e9 931f                          push r17
0002ea 932f                          push r18
                                 
0002eb 9100 0108                     lds r16, modo_edicion
                                 
0002ed 3001                          cpi r16, MODO_HORA
0002ee f451                          brne DC_MIN
0002ef 9110 0100                     lds r17, horas
0002f1 2311                          tst r17
0002f2 f411                          brne DC_DEC_HORA
0002f3 e117                          ldi r17, 23
0002f4 c001                          rjmp DC_GUARDAR_HORA
                                 DC_DEC_HORA:
0002f5 951a                          dec r17
                                 DC_GUARDAR_HORA:
0002f6 9310 0100                     sts horas, r17
0002f8 c047                          rjmp DC_FIN
                                 
                                 DC_MIN:
0002f9 3002                          cpi r16, MODO_MINUTO
0002fa f469                          brne DC_DIA
0002fb 9110 0101                     lds r17, minutos
0002fd 2311                          tst r17
0002fe f411                          brne DC_DEC_MIN
0002ff e31b                          ldi r17, 59
000300 c001                          rjmp DC_GUARDAR_MIN
                                 DC_DEC_MIN:
000301 951a                          dec r17
                                 DC_GUARDAR_MIN:
000302 9310 0101                     sts minutos, r17
000304 2711                          clr r17
000305 9310 0102                     sts segundos, r17
000307 c038                          rjmp DC_FIN
                                 
                                 DC_DIA:
