                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x100
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; modos de operacion del reloj
                                 .equ MODO_NORMAL   = 0
                                 .equ MODO_HORA     = 1
                                 .equ MODO_MINUTO   = 2
                                 .equ MODO_DIA      = 3
                                 .equ MODO_MES      = 4
                                 .equ MODO_ALARM_H  = 5
                                 .equ MODO_ALARM_M  = 6
                                 
                                 ; vistas disponibles en pantalla
                                 .equ VISTA_HORA    = 0
                                 .equ VISTA_FECHA   = 1
                                 .equ VISTA_ALARMA  = 2
                                 
                                 ; posiciones de bit de cada boton en los registros de estado
                                 .equ BIT_BTN_VER   = 0
                                 .equ BIT_BTN_SUB   = 1
                                 .equ BIT_BTN_BAJ   = 2
                                 .equ BIT_BTN_MOD   = 3
                                 
                                 ; codigo especial para apagar todos los segmentos de un digito
                                 .equ COD_VACIO     = 10
                                 
                                 ; registros de trabajo temporales
                                 .def tmp0  = r16
                                 .def tmp1  = r17
                                 .def tmp2  = r18
                                 .def tmp3  = r19
                                 .def tmp4  = r20
                                 
                                 .dseg
                                 
                                 ; variables del reloj
000100                           horas:         .byte 1
000101                           minutos:       .byte 1
000102                           segundos:      .byte 1
000103                           dia:           .byte 1
000104                           mes:           .byte 1
                                 
                                 ; configuracion de la alarma
000105                           alar_hora:     .byte 1
000106                           alar_min:      .byte 1
                                 
                                 ; estado general de la interfaz
000107                           vista_actual:  .byte 1
000108                           modo_edicion:  .byte 1
                                 
                                 ; variables de temporizacion y parpadeo
000109                           flag_parpadeo: .byte 1
00010a                           cnt_ms_l:      .byte 1
00010b                           cnt_ms_h:      .byte 1
00010c                           cnt_500_l:     .byte 1
00010d                           cnt_500_h:     .byte 1
                                 
                                 ; indice del digito que se refresca en el multiplex
00010e                           indice_mux:    .byte 1
                                 
                                 ; patrones de segmento para cada digito del display
00010f                           seg_d0:        .byte 1
000110                           seg_d1:        .byte 1
000111                           seg_d2:        .byte 1
000112                           seg_d3:        .byte 1
                                 
                                 ; registros de eventos y bloqueos de botones
000113                           bloqueos:      .byte 1
000114                           eventos:       .byte 1
                                 
                                 ; estado de la alarma
000115                           alarma_sonando:  .byte 1
000116                           alarma_usada:    .byte 1
                                 
                                 ; control del LED de dos puntos y del LED indicador
000117                           puntos_on:     .byte 1
000118                           led_alarma:    .byte 1
                                 
                                 .cseg
                                 
                                 ; solo se usan los vectores de PCINT1 y TIMER0 COMPA
                                 .org 0x0000
000000 c022                          rjmp INICIO
                                 
                                 .org 0x0008
000008 c0ba                          rjmp ISR_BOTONES
                                 
                                 .org 0x001C
00001c c061                          rjmp ISR_TICK_MS
                                 
                                 ; tabla de patrones para display de 7 segmentos
                                 ; el bit 6 corresponde al segmento A y el bit 0 al segmento G
                                 TABLA_SEG:
00001d 307e
00001e 796d
00001f 5b33
000020 705f
000021 7b7f
000022 0000                          .db 0b1111110, 0b0110000, 0b1101101, 0b1111001, 0b0110011, 0b1011011, 0b1011111, 0b1110000, 0b1111111, 0b1111011, 0b0000000, 0b0000000
                                 
                                 ; rutina de inicializacion del sistema
                                 INICIO:
000023 e008                          ldi tmp0, high(RAMEND)
000024 bf0e                          out SPH, tmp0
000025 ef0f                          ldi tmp0, low(RAMEND)
000026 bf0d                          out SPL, tmp0
000027 2411                          clr r1
                                 
                                     ; hora inicial al encender
000028 e00c                          ldi tmp0, 12
000029 9300 0100                     sts horas, tmp0
00002b 2700                          clr tmp0
00002c 9300 0101                     sts minutos, tmp0
00002e 9300 0102                     sts segundos, tmp0
                                 
                                     ; fecha inicial al encender
000030 e001                          ldi tmp0, 1
000031 9300 0103                     sts dia, tmp0
000033 9300 0104                     sts mes, tmp0
                                 
                                     ; alarma predeterminada a las seis de la manana
000035 e006                          ldi tmp0, 6
000036 9300 0105                     sts alar_hora, tmp0
000038 2700                          clr tmp0
000039 9300 0106                     sts alar_min, tmp0
                                 
                                     ; poner en cero todas las variables de control
00003b 2700                          clr tmp0
00003c 9300 0107                     sts vista_actual, tmp0
00003e 9300 0108                     sts modo_edicion, tmp0
000040 9300 0109                     sts flag_parpadeo, tmp0
000042 9300 010a                     sts cnt_ms_l, tmp0
000044 9300 010b                     sts cnt_ms_h, tmp0
000046 9300 010c                     sts cnt_500_l, tmp0
000048 9300 010d                     sts cnt_500_h, tmp0
00004a 9300 010e                     sts indice_mux, tmp0
00004c 9300 0113                     sts bloqueos, tmp0
00004e 9300 0114                     sts eventos, tmp0
000050 9300 0115                     sts alarma_sonando, tmp0
000052 9300 0116                     sts alarma_usada, tmp0
000054 9300 0117                     sts puntos_on, tmp0
000056 9300 0118                     sts led_alarma, tmp0
000058 9300 010f                     sts seg_d0, tmp0
00005a 9300 0110                     sts seg_d1, tmp0
00005c 9300 0111                     sts seg_d2, tmp0
00005e 9300 0112                     sts seg_d3, tmp0
                                 
                                     ; PB0 a PB5 como salidas para los segmentos y el LED de dos puntos
000060 e30f                          ldi tmp0, 0b00111111
000061 b904                          out DDRB, tmp0
                                 
                                     ; PD2 a PD7 como salidas para seleccion de digito y segmentos F G
000062 ef0c                          ldi tmp0, 0b11111100
000063 b90a                          out DDRD, tmp0
000064 2700                          clr tmp0
000065 b90b                          out PORTD, tmp0
                                 
                                     ; PC0 a PC3 entradas para botones PC4 salida LED PC5 salida buzzer
000066 e300                          ldi tmp0, 0b00110000
000067 b907                          out DDRC, tmp0
                                 
                                     ; activar resistencias de pull up internas en los pines de botones
000068 e00f                          ldi tmp0, 0b00001111
000069 b908                          out PORTC, tmp0
                                 
                                     ; habilitar interrupcion por cambio de pin solo en el grupo de PORTC
00006a e002                          ldi tmp0, (1<<PCIE1)
00006b 9300 0068                     sts PCICR, tmp0
                                 
                                     ; seleccionar solo los pines PC0 a PC3 dentro del grupo PORTC
00006d e00f                          ldi tmp0, (1<<PCINT8)|(1<<PCINT9)|(1<<PCINT10)|(1<<PCINT11)
00006e 9300 006c                     sts PCMSK1, tmp0
                                 
                                     ; configurar Timer0 en modo CTC con interrupcion cada un milisegundo
000070 e002                          ldi tmp0, (1<<WGM01)
000071 bd04                          out TCCR0A, tmp0
000072 e003                          ldi tmp0, (1<<CS01)|(1<<CS00)
000073 bd05                          out TCCR0B, tmp0
000074 ef09                          ldi tmp0, 249
000075 bd07                          out OCR0A, tmp0
000076 e002                          ldi tmp0, (1<<OCIE0A)
000077 9300 006e                     sts TIMSK0, tmp0
                                 
000079 9478                          sei
                                 
                                 CICLO_PRINCIPAL:
00007a d07c                          rcall PROCESAR_BOTONES
00007b d0ec                          rcall ACTUALIZAR_SALIDAS
00007c d10b                          rcall CONSTRUIR_BUFFER
00007d cffc                          rjmp CICLO_PRINCIPAL
                                 
                                 
                                 ; interrupcion del Timer0 que se ejecuta cada milisegundo
                                 ISR_TICK_MS:
00007e 930f                          push r16
00007f b70f                          in   r16, SREG
000080 930f                          push r16
000081 931f                          push r17
000082 932f                          push r18
000083 933f                          push r19
000084 934f                          push r20
000085 938f                          push r24
000086 939f                          push r25
000087 93ef                          push r30
000088 93ff                          push r31
                                 
                                     ; contar hasta 500 milisegundos para controlar el parpadeo
000089 9180 010c                     lds r24, cnt_500_l
00008b 9190 010d                     lds r25, cnt_500_h
00008d 9601                          adiw r24, 1
00008e 9380 010c                     sts cnt_500_l, r24
000090 9390 010d                     sts cnt_500_h, r25
                                 
000092 ef04                          ldi r16, low(500)
000093 e011                          ldi r17, high(500)
000094 1780                          cp  r24, r16
000095 0791                          cpc r25, r17
000096 f459                          brne TICK_SALTAR_500
                                 
                                     ; al llegar a 500 ms resetear el contador e invertir el flag de parpadeo
000097 2700                          clr r16
000098 9300 010c                     sts cnt_500_l, r16
00009a 9300 010d                     sts cnt_500_h, r16
00009c 9100 0109                     lds r16, flag_parpadeo
00009e e011                          ldi r17, 1
00009f 2701                          eor r16, r17
0000a0 9300 0109                     sts flag_parpadeo, r16
                                 
                                 TICK_SALTAR_500:
                                     ; contar hasta 1000 milisegundos para el tick de segundos
0000a2 9180 010a                     lds r24, cnt_ms_l
0000a4 9190 010b                     lds r25, cnt_ms_h
0000a6 9601                          adiw r24, 1
0000a7 9380 010a                     sts cnt_ms_l, r24
0000a9 9390 010b                     sts cnt_ms_h, r25
                                 
0000ab ee08                          ldi r16, low(1000)
0000ac e013                          ldi r17, high(1000)
0000ad 1780                          cp  r24, r16
0000ae 0791                          cpc r25, r17
0000af f431                          brne TICK_SALTAR_1S
                                 
                                     ; al completar el segundo resetear y avanzar el reloj
0000b0 2700                          clr r16
0000b1 9300 010a                     sts cnt_ms_l, r16
0000b3 9300 010b                     sts cnt_ms_h, r16
0000b5 d18a                          rcall AVANZAR_SEGUNDO
                                 
                                 TICK_SALTAR_1S:
0000b6 d142                          rcall REFRESCAR_DISPLAY
                                 
0000b7 91ff                          pop r31
0000b8 91ef                          pop r30
0000b9 919f                          pop r25
0000ba 918f                          pop r24
0000bb 914f                          pop r20
0000bc 913f                          pop r19
0000bd 912f                          pop r18
0000be 911f                          pop r17
0000bf 910f                          pop r16
0000c0 bf0f                          out SREG, r16
0000c1 910f                          pop r16
0000c2 9518                          reti
                                 
                                 
                                 ; interrupcion que detecta cambios en los pines de botones PC0 a PC3
                                 ISR_BOTONES:
0000c3 930f                          push r16
0000c4 b70f                          in   r16, SREG
0000c5 930f                          push r16
0000c6 931f                          push r17
0000c7 932f                          push r18
                                 
                                     ; leer el estado actual de los pines de botones
0000c8 b106                          in  r16, PINC
0000c9 9110 0113                     lds r17, bloqueos
0000cb 9120 0114                     lds r18, eventos
                                 
                                     ; verificar boton VER en PC0
0000cd ff00                          sbrs r16, 0
0000ce c005                          rjmp BTN0_PRESIONADO
                                 BTN0_SOLTADO:
0000cf ff10                          sbrs r17, BIT_BTN_VER
0000d0 c004                          rjmp VER_PC1
0000d1 7f1e                          cbr r17, (1<<BIT_BTN_VER)
0000d2 6021                          sbr r18, (1<<BIT_BTN_VER)
0000d3 c001                          rjmp VER_PC1
                                 BTN0_PRESIONADO:
0000d4 6011                          sbr r17, (1<<BIT_BTN_VER)
                                 
                                 VER_PC1:
                                     ; verificar boton SUBIR en PC1
0000d5 ff01                          sbrs r16, 1
0000d6 c005                          rjmp BTN1_PRESIONADO
                                 BTN1_SOLTADO:
0000d7 ff11                          sbrs r17, BIT_BTN_SUB
0000d8 c004                          rjmp VER_PC2
0000d9 7f1d                          cbr r17, (1<<BIT_BTN_SUB)
0000da 6022                          sbr r18, (1<<BIT_BTN_SUB)
0000db c001                          rjmp VER_PC2
                                 BTN1_PRESIONADO:
0000dc 6012                          sbr r17, (1<<BIT_BTN_SUB)
                                 
                                 VER_PC2:
                                     ; verificar boton BAJAR en PC2
0000dd ff02                          sbrs r16, 2
0000de c005                          rjmp BTN2_PRESIONADO
                                 BTN2_SOLTADO:
0000df ff12                          sbrs r17, BIT_BTN_BAJ
0000e0 c004                          rjmp VER_PC3
0000e1 7f1b                          cbr r17, (1<<BIT_BTN_BAJ)
0000e2 6024                          sbr r18, (1<<BIT_BTN_BAJ)
0000e3 c001                          rjmp VER_PC3
                                 BTN2_PRESIONADO:
0000e4 6014                          sbr r17, (1<<BIT_BTN_BAJ)
                                 
                                 VER_PC3:
                                     ; verificar boton MODO en PC3
0000e5 ff03                          sbrs r16, 3
0000e6 c005                          rjmp BTN3_PRESIONADO
                                 BTN3_SOLTADO:
0000e7 ff13                          sbrs r17, BIT_BTN_MOD
0000e8 c004                          rjmp FIN_ISR_BTN
0000e9 7f17                          cbr r17, (1<<BIT_BTN_MOD)
0000ea 6028                          sbr r18, (1<<BIT_BTN_MOD)
0000eb c001                          rjmp FIN_ISR_BTN
                                 BTN3_PRESIONADO:
0000ec 6018                          sbr r17, (1<<BIT_BTN_MOD)
                                 
                                 FIN_ISR_BTN:
0000ed 9310 0113                     sts bloqueos, r17
0000ef 9320 0114                     sts eventos, r18
                                 
0000f1 912f                          pop r18
0000f2 911f                          pop r17
0000f3 910f                          pop r16
0000f4 bf0f                          out SREG, r16
0000f5 910f                          pop r16
0000f6 9518                          reti
                                 
                                 
                                 ; lee los eventos pendientes y ejecuta la accion correspondiente
                                 PROCESAR_BOTONES:
0000f7 930f                          push r16
0000f8 931f                          push r17
                                 
0000f9 9100 0114                     lds r16, eventos
0000fb 2300                          tst r16
0000fc f109                          breq PB_SALIR
                                 
                                     ; el boton MODO tiene prioridad sobre los demas
0000fd ff03                          sbrs r16, BIT_BTN_MOD
0000fe c005                          rjmp PB_VER_VISTA
0000ff 7f07                          cbr r16, (1<<BIT_BTN_MOD)
000100 9300 0114                     sts eventos, r16
000102 d01e                          rcall ACCION_MODO
000103 c01a                          rjmp PB_SALIR
                                 
                                 PB_VER_VISTA:
000104 9100 0114                     lds r16, eventos
000106 ff00                          sbrs r16, BIT_BTN_VER
000107 c005                          rjmp PB_VER_SUBIR
000108 7f0e                          cbr r16, (1<<BIT_BTN_VER)
000109 9300 0114                     sts eventos, r16
00010b d04d                          rcall ACCION_VISTA
00010c c011                          rjmp PB_SALIR
                                 
                                 PB_VER_SUBIR:
00010d 9100 0114                     lds r16, eventos
00010f ff01                          sbrs r16, BIT_BTN_SUB
000110 c005                          rjmp PB_VER_BAJAR
000111 7f0d                          cbr r16, (1<<BIT_BTN_SUB)
000112 9300 0114                     sts eventos, r16
000114 d17c                          rcall INCREMENTAR_CAMPO
000115 c008                          rjmp PB_SALIR
                                 
                                 PB_VER_BAJAR:
000116 9100 0114                     lds r16, eventos
000118 ff02                          sbrs r16, BIT_BTN_BAJ
000119 c004                          rjmp PB_SALIR
00011a 7f0b                          cbr r16, (1<<BIT_BTN_BAJ)
00011b 9300 0114                     sts eventos, r16
00011d d1ca                          rcall DECREMENTAR_CAMPO
                                 
                                 PB_SALIR:
00011e 911f                          pop r17
00011f 910f                          pop r16
000120 9508                          ret
                                 
                                 
                                 ; maneja la pulsacion del boton MODO
                                 ACCION_MODO:
000121 930f                          push r16
000122 931f                          push r17
                                 
                                     ; si la alarma esta sonando este boton la silencia
000123 9100 0115                     lds r16, alarma_sonando
000125 2300                          tst r16
000126 f021                          breq AM_AVANZAR_MODO
000127 2700                          clr r16
000128 9300 0115                     sts alarma_sonando, r16
00012a c02b                          rjmp AM_FIN
                                 
                                 AM_AVANZAR_MODO:
                                     ; avanzar al siguiente modo de edicion con vuelta al inicio en 7
00012b 9100 0108                     lds r16, modo_edicion
00012d 9503                          inc r16
00012e 3007                          cpi r16, 7
00012f f008                          brlo AM_GUARDAR
000130 2700                          clr r16
                                 
                                 AM_GUARDAR:
000131 9300 0108                     sts modo_edicion, r16
                                 
                                     ; forzar la vista correspondiente al modo recien activado
000133 3001                          cpi r16, MODO_HORA
000134 f421                          brne AM_C1
000135 e010                          ldi r17, VISTA_HORA
000136 9310 0107                     sts vista_actual, r17
000138 c01d                          rjmp AM_FIN
                                 
                                 AM_C1:
000139 3002                          cpi r16, MODO_MINUTO
00013a f421                          brne AM_C2
00013b e010                          ldi r17, VISTA_HORA
00013c 9310 0107                     sts vista_actual, r17
00013e c017                          rjmp AM_FIN
                                 
                                 AM_C2:
00013f 3003                          cpi r16, MODO_DIA
000140 f421                          brne AM_C3
000141 e011                          ldi r17, VISTA_FECHA
000142 9310 0107                     sts vista_actual, r17
000144 c011                          rjmp AM_FIN
                                 
                                 AM_C3:
000145 3004                          cpi r16, MODO_MES
000146 f421                          brne AM_C4
000147 e011                          ldi r17, VISTA_FECHA
000148 9310 0107                     sts vista_actual, r17
00014a c00b                          rjmp AM_FIN
                                 
                                 AM_C4:
00014b 3005                          cpi r16, MODO_ALARM_H
00014c f421                          brne AM_C5
00014d e012                          ldi r17, VISTA_ALARMA
00014e 9310 0107                     sts vista_actual, r17
000150 c005                          rjmp AM_FIN
                                 
                                 AM_C5:
000151 3006                          cpi r16, MODO_ALARM_M
000152 f419                          brne AM_FIN
000153 e012                          ldi r17, VISTA_ALARMA
000154 9310 0107                     sts vista_actual, r17
                                 
                                 AM_FIN:
000156 911f                          pop r17
000157 910f                          pop r16
000158 9508                          ret
                                 
                                 
                                 ; maneja la pulsacion del boton VER cambiando la vista activa
                                 ACCION_VISTA:
000159 930f                          push r16
                                 
                                     ; la vista solo cambia cuando no hay ningun campo en edicion
00015a 9100 0108                     lds r16, modo_edicion
00015c 2300                          tst r16
00015d f441                          brne AV_FIN
                                 
00015e 9100 0107                     lds r16, vista_actual
000160 9503                          inc r16
000161 3003                          cpi r16, 3
000162 f008                          brlo AV_GUARDAR
000163 2700                          clr r16
                                 
                                 AV_GUARDAR:
000164 9300 0107                     sts vista_actual, r16
                                 
                                 AV_FIN:
000166 910f                          pop r16
000167 9508                          ret
                                 
                                 
                                 ; actualiza el estado del LED de dos puntos y del LED indicador de alarma
                                 ACTUALIZAR_SALIDAS:
000168 930f                          push r16
000169 931f                          push r17
                                 
                                     ; en vista fecha los dos puntos permanecen fijos encendidos
00016a 9100 0107                     lds r16, vista_actual
00016c 3001                          cpi r16, VISTA_FECHA
00016d f421                          brne AS_NO_FECHA
00016e e011                          ldi r17, 1
00016f 9310 0117                     sts puntos_on, r17
000171 c004                          rjmp AS_LED_ALARMA
                                 
                                 AS_NO_FECHA:
                                     ; en otras vistas los dos puntos parpadean siguiendo el flag de parpadeo
000172 9110 0109                     lds r17, flag_parpadeo
000174 9310 0117                     sts puntos_on, r17
                                 
                                 AS_LED_ALARMA:
                                     ; el LED indicador se enciende al ver o editar la alarma
000176 2711                          clr r17
000177 9100 0107                     lds r16, vista_actual
000179 3002                          cpi r16, VISTA_ALARMA
00017a f039                          breq AS_LED_ON
00017b 9100 0108                     lds r16, modo_edicion
00017d 3005                          cpi r16, MODO_ALARM_H
00017e f019                          breq AS_LED_ON
00017f 3006                          cpi r16, MODO_ALARM_M
000180 f009                          breq AS_LED_ON
000181 c001                          rjmp AS_GUARDAR_LED
                                 
                                 AS_LED_ON:
000182 e011                          ldi r17, 1
                                 
                                 AS_GUARDAR_LED:
000183 9310 0118                     sts led_alarma, r17
                                 
000185 911f                          pop r17
000186 910f                          pop r16
000187 9508                          ret
                                 
                                 
                                 ; arma el contenido del buffer de display segun la vista y el modo activos
                                 CONSTRUIR_BUFFER:
000188 930f                          push r16
000189 931f                          push r17
00018a 932f                          push r18
00018b 933f                          push r19
00018c 934f                          push r20
00018d 935f                          push r21
00018e 938f                          push r24
00018f 939f                          push r25
000190 93ef                          push r30
000191 93ff                          push r31
                                 
                                     ; seleccionar los dos valores a mostrar segun la vista activa
000192 9100 0107                     lds r16, vista_actual
000194 3000                          cpi r16, VISTA_HORA
000195 f429                          brne CB_VER_FECHA
000196 9100 0100                     lds r16, horas
000198 9110 0101                     lds r17, minutos
00019a c00d                          rjmp CB_SEPARAR
                                 
                                 CB_VER_FECHA:
00019b 9120 0107                     lds r18, vista_actual
00019d 3021                          cpi r18, VISTA_FECHA
00019e f429                          brne CB_CARGAR_ALARMA
00019f 9100 0103                     lds r16, dia
0001a1 9110 0104                     lds r17, mes
0001a3 c004                          rjmp CB_SEPARAR
                                 
                                 CB_CARGAR_ALARMA:
0001a4 9100 0105                     lds r16, alar_hora
0001a6 9110 0106                     lds r17, alar_min
                                 
                                 CB_SEPARAR:
                                     ; separar el valor izquierdo en decenas y unidades
0001a8 2f80                          mov r24, r16
0001a9 d039                          rcall SEPARAR_DECIMAL
0001aa 2f28                          mov r18, r24
0001ab 2f39                          mov r19, r25
                                 
                                     ; separar el valor derecho en decenas y unidades
0001ac 2f81                          mov r24, r17
0001ad d035                          rcall SEPARAR_DECIMAL
0001ae 2f48                          mov r20, r24
0001af 2f59                          mov r21, r25
                                 
                                     ; cuando el flag de parpadeo esta en cero blanquear el campo en edicion
0001b0 9100 0109                     lds r16, flag_parpadeo
0001b2 2300                          tst r16
0001b3 f4a1                          brne CB_CONVERTIR
                                 
0001b4 9100 0108                     lds r16, modo_edicion
0001b6 3001                          cpi r16, MODO_HORA
0001b7 f059                          breq CB_BLANQUEAR_IZQ
0001b8 3003                          cpi r16, MODO_DIA
0001b9 f049                          breq CB_BLANQUEAR_IZQ
0001ba 3005                          cpi r16, MODO_ALARM_H
0001bb f039                          breq CB_BLANQUEAR_IZQ
0001bc 3002                          cpi r16, MODO_MINUTO
0001bd f041                          breq CB_BLANQUEAR_DER
0001be 3004                          cpi r16, MODO_MES
0001bf f031                          breq CB_BLANQUEAR_DER
0001c0 3006                          cpi r16, MODO_ALARM_M
0001c1 f021                          breq CB_BLANQUEAR_DER
0001c2 c005                          rjmp CB_CONVERTIR
                                 
                                 CB_BLANQUEAR_IZQ:
0001c3 e02a                          ldi r18, COD_VACIO
0001c4 e03a                          ldi r19, COD_VACIO
0001c5 c002                          rjmp CB_CONVERTIR
                                 
                                 CB_BLANQUEAR_DER:
0001c6 e04a                          ldi r20, COD_VACIO
0001c7 e05a                          ldi r21, COD_VACIO
                                 
                                 CB_CONVERTIR:
                                     ; convertir cada digito a su patron de segmentos y guardarlo en el buffer
0001c8 2f82                          mov r24, r18
0001c9 d025                          rcall DIGITO_A_SEG
0001ca 9380 010f                     sts seg_d0, r24
                                 
0001cc 2f83                          mov r24, r19
0001cd d021                          rcall DIGITO_A_SEG
0001ce 9380 0110                     sts seg_d1, r24
                                 
0001d0 2f84                          mov r24, r20
0001d1 d01d                          rcall DIGITO_A_SEG
0001d2 9380 0111                     sts seg_d2, r24
                                 
0001d4 2f85                          mov r24, r21
0001d5 d019                          rcall DIGITO_A_SEG
0001d6 9380 0112                     sts seg_d3, r24
                                 
0001d8 91ff                          pop r31
0001d9 91ef                          pop r30
0001da 919f                          pop r25
0001db 918f                          pop r24
0001dc 915f                          pop r21
0001dd 914f                          pop r20
0001de 913f                          pop r19
0001df 912f                          pop r18
0001e0 911f                          pop r17
0001e1 910f                          pop r16
0001e2 9508                          ret
                                 
                                 
                                 ; separa un numero de dos cifras en su decena y su unidad
                                 ; recibe el valor en r24 y devuelve decenas en r24 y unidades en r25
                                 SEPARAR_DECIMAL:
0001e3 930f                          push r16
0001e4 2700                          clr r16
0001e5 2799                          clr r25
                                 
                                 SD_BUCLE:
0001e6 308a                          cpi r24, 10
0001e7 f018                          brlo SD_FIN
0001e8 508a                          subi r24, 10
0001e9 9503                          inc r16
0001ea cffb                          rjmp SD_BUCLE
                                 
                                 SD_FIN:
0001eb 2f98                          mov r25, r24
0001ec 2f80                          mov r24, r16
0001ed 910f                          pop r16
0001ee 9508                          ret
                                 
                                 
                                 ; consulta la tabla en flash y devuelve el patron de segmentos para el digito dado
                                 ; recibe el indice en r24 y devuelve el patron en r24
                                 DIGITO_A_SEG:
0001ef 93ff                          push ZH
0001f0 93ef                          push ZL
0001f1 e0f0                          ldi ZH, high(TABLA_SEG<<1)
0001f2 e3ea                          ldi ZL, low(TABLA_SEG<<1)
0001f3 0fe8                          add ZL, r24
0001f4 1df1                          adc ZH, r1
0001f5 9184                          lpm r24, Z
0001f6 91ef                          pop ZL
0001f7 91ff                          pop ZH
0001f8 9508                          ret
                                 
                                 
                                 ; enciende un digito del display por vez ciclando entre los cuatro disponibles
                                 REFRESCAR_DISPLAY:
0001f9 930f                          push r16
0001fa 931f                          push r17
0001fb 932f                          push r18
0001fc 933f                          push r19
0001fd 934f                          push r20
                                 
0001fe 9100 010e                     lds r16, indice_mux
                                 
000200 3000                          cpi r16, 0
000201 f421                          brne RD_CHK1
000202 9110 010f                     lds r17, seg_d0
000204 e220                          ldi r18, (1<<PD5)
000205 c00f                          rjmp RD_SALIDA
                                 
                                 RD_CHK1:
000206 3001                          cpi r16, 1
000207 f421                          brne RD_CHK2
000208 9110 0110                     lds r17, seg_d1
00020a e120                          ldi r18, (1<<PD4)
00020b c009                          rjmp RD_SALIDA
                                 
                                 RD_CHK2:
00020c 3002                          cpi r16, 2
00020d f421                          brne RD_CHK3
00020e 9110 0111                     lds r17, seg_d2
000210 e028                          ldi r18, (1<<PD3)
000211 c003                          rjmp RD_SALIDA
                                 
                                 RD_CHK3:
000212 9110 0112                     lds r17, seg_d3
000214 e024                          ldi r18, (1<<PD2)
                                 
                                 RD_SALIDA:
                                     ; escribir segmentos A a E en PORTB y el LED de dos puntos en PB5
000215 2f31                          mov r19, r17
000216 9536                          lsr r19
000217 9536                          lsr r19
000218 713f                          andi r19, 0b00011111
                                 
000219 9140 0117                     lds r20, puntos_on
00021b 2344                          tst r20
00021c f009                          breq RD_SIN_PUNTOS
00021d 6230                          ori r19, (1<<PB5)
                                 
                                 RD_SIN_PUNTOS:
00021e b935                          out PORTB, r19
                                 
                                     ; escribir segmentos F y G en PORTD junto con la linea de seleccion del digito
00021f 2733                          clr r19
000220 fd11                          sbrc r17, 1
000221 6830                          ori r19, (1<<PD7)
000222 fd10                          sbrc r17, 0
000223 6430                          ori r19, (1<<PD6)
000224 2b32                          or  r19, r18
000225 b93b                          out PORTD, r19
                                 
                                     ; escribir en PORTC manteniendo los pull ups y activando LED y buzzer si corresponde
000226 e03f                          ldi r19, 0b00001111
                                 
000227 9140 0118                     lds r20, led_alarma
000229 2344                          tst r20
00022a f009                          breq RD_SIN_LED
00022b 6130                          ori r19, (1<<PC4)
                                 
                                 RD_SIN_LED:
00022c 9140 0115                     lds r20, alarma_sonando
00022e 2344                          tst r20
00022f f009                          breq RD_SIN_BUZZER
000230 6230                          ori r19, (1<<PC5)
                                 
                                 RD_SIN_BUZZER:
000231 b938                          out PORTC, r19
                                 
                                     ; avanzar al siguiente digito y volver a cero al llegar a cuatro
000232 9100 010e                     lds r16, indice_mux
000234 9503                          inc r16
000235 3004                          cpi r16, 4
000236 f008                          brlo RD_GUARDAR
000237 2700                          clr r16
                                 
                                 RD_GUARDAR:
000238 9300 010e                     sts indice_mux, r16
                                 
00023a 914f                          pop r20
00023b 913f                          pop r19
00023c 912f                          pop r18
00023d 911f                          pop r17
00023e 910f                          pop r16
00023f 9508                          ret
                                 
                                 
                                 ; incrementa segundos minutos horas y delega el avance de fecha cuando corresponde
                                 AVANZAR_SEGUNDO:
000240 930f                          push r16
000241 931f                          push r17
                                 
000242 9100 0102                     lds r16, segundos
000244 9503                          inc r16
000245 330c                          cpi r16, 60
000246 f0d8                          brlo AVS_GUARDAR_SEG
                                 
000247 2700                          clr r16
000248 9300 0102                     sts segundos, r16
                                 
00024a 9100 0101                     lds r16, minutos
00024c 9503                          inc r16
00024d 330c                          cpi r16, 60
00024e f080                          brlo AVS_GUARDAR_MIN
                                 
00024f 2700                          clr r16
000250 9300 0101                     sts minutos, r16
                                 
000252 9100 0100                     lds r16, horas
000254 9503                          inc r16
000255 3108                          cpi r16, 24
000256 f028                          brlo AVS_GUARDAR_HORA
                                 
000257 2700                          clr r16
000258 9300 0100                     sts horas, r16
00025a d0e9                          rcall AVANZAR_DIA
00025b c008                          rjmp AVS_VER_ALARMA
                                 
                                 AVS_GUARDAR_HORA:
00025c 9300 0100                     sts horas, r16
00025e c005                          rjmp AVS_VER_ALARMA
                                 
                                 AVS_GUARDAR_MIN:
00025f 9300 0101                     sts minutos, r16
000261 c002                          rjmp AVS_VER_ALARMA
                                 
                                 AVS_GUARDAR_SEG:
000262 9300 0102                     sts segundos, r16
                                 
                                 AVS_VER_ALARMA:
                                     ; la alarma solo se activa en el segundo cero del minuto coincidente
000264 9100 0102                     lds r16, segundos
000266 2300                          tst r16
000267 f4b1                          brne AVS_LIMPIAR_SI_TOCA
                                 
000268 9100 0100                     lds r16, horas
00026a 9110 0105                     lds r17, alar_hora
00026c 1701                          cp  r16, r17
00026d f481                          brne AVS_LIMPIAR_SI_TOCA
                                 
00026e 9100 0101                     lds r16, minutos
000270 9110 0106                     lds r17, alar_min
000272 1701                          cp  r16, r17
000273 f451                          brne AVS_LIMPIAR_SI_TOCA
                                 
                                     ; verificar que no se haya activado ya en este mismo minuto
000274 9100 0116                     lds r16, alarma_usada
000276 2300                          tst r16
000277 f4b1                          brne AVS_FIN
                                 
000278 e001                          ldi r16, 1
000279 9300 0115                     sts alarma_sonando, r16
00027b 9300 0116                     sts alarma_usada, r16
00027d c010                          rjmp AVS_FIN
                                 
                                 AVS_LIMPIAR_SI_TOCA:
                                     ; si la hora y el minuto ya no coinciden liberar el seguro para la proxima vez
00027e 9100 0100                     lds r16, horas
000280 9110 0105                     lds r17, alar_hora
000282 1701                          cp  r16, r17
000283 f439                          brne AVS_LIBERAR_SEGURO
                                 
000284 9100 0101                     lds r16, minutos
000286 9110 0106                     lds r17, alar_min
000288 1701                          cp  r16, r17
000289 f409                          brne AVS_LIBERAR_SEGURO
                                 
00028a c003                          rjmp AVS_FIN
                                 
                                 AVS_LIBERAR_SEGURO:
00028b 2700                          clr r16
00028c 9300 0116                     sts alarma_usada, r16
                                 
                                 AVS_FIN:
00028e 911f                          pop r17
00028f 910f                          pop r16
000290 9508                          ret
                                 
                                 
                                 ; incrementa el campo que esta siendo editado segun el modo activo
                                 INCREMENTAR_CAMPO:
