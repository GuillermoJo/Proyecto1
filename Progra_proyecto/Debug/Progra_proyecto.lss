                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x100
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; Reloj + Fecha + Alarma
                                 ; ATmega328P - AVR Assembler
                                 ;========================================================
                                 
                                 .include "m328pdef.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;========================================================
                                 ; Constantes
                                 ;========================================================
                                 .equ MODE_NORMAL    = 0
                                 .equ MODE_SET_HOUR  = 1
                                 .equ MODE_SET_MIN   = 2
                                 .equ MODE_SET_DAY   = 3
                                 .equ MODE_SET_MON   = 4
                                 .equ MODE_SET_AH    = 5
                                 .equ MODE_SET_AM    = 6
                                 
                                 .equ VIEW_TIME      = 0
                                 .equ VIEW_DATE      = 1
                                 .equ VIEW_ALARM     = 2
                                 
                                 .equ BTN_VIEW_BIT   = 0
                                 .equ BTN_UP_BIT     = 1
                                 .equ BTN_DOWN_BIT   = 2
                                 .equ BTN_MODE_BIT   = 3
                                 
                                 .equ BLANK_CODE     = 10
                                 
                                 ;========================================================
                                 ; SRAM
                                 ;========================================================
                                 .dseg
000100                           hour:               .byte 1
000101                           minute:             .byte 1
000102                           second:             .byte 1
000103                           day:                .byte 1
000104                           month:              .byte 1
                                 
000105                           alarm_hour:         .byte 1
000106                           alarm_min:          .byte 1
                                 
000107                           current_view:       .byte 1
000108                           edit_mode:          .byte 1
                                 
000109                           blink_flag:         .byte 1
00010a                           ms_count_l:         .byte 1
00010b                           ms_count_h:         .byte 1
00010c                           halfsec_l:          .byte 1
00010d                           halfsec_h:          .byte 1
                                 
00010e                           scan_idx:           .byte 1
                                 
00010f                           disp0:              .byte 1
000110                           disp1:              .byte 1
000111                           disp2:              .byte 1
000112                           disp3:              .byte 1
                                 
000113                           btn_locks:          .byte 1
000114                           btn_events:         .byte 1
                                 
000115                           alarm_ringing:      .byte 1
000116                           alarm_latched:      .byte 1
                                 
000117                           colon_on:           .byte 1
000118                           aux_led:            .byte 1
                                 
                                 .cseg
                                 
                                 ;========================================================
                                 ; Vectores de interrupción
                                 ;========================================================
                                 .org 0x0000
000000 c038                          rjmp RESET
                                 
                                 .org 0x0002
000002 9518                          reti
                                 .org 0x0004
000004 9518                          reti
                                 .org 0x0006
000006 9518                          reti
                                 .org 0x0008
000008 c0d5                          rjmp ISR_PCINT1
                                 .org 0x000A
00000a 9518                          reti
                                 .org 0x000C
00000c 9518                          reti
                                 .org 0x000E
00000e 9518                          reti
                                 .org 0x0010
000010 9518                          reti
                                 .org 0x0012
000012 9518                          reti
                                 .org 0x0014
000014 9518                          reti
                                 .org 0x0016
000016 9518                          reti
                                 .org 0x0018
000018 9518                          reti
                                 .org 0x001A
00001a 9518                          reti
                                 .org 0x001C
00001c c076                          rjmp ISR_TIMER0_COMPA
                                 .org 0x001E
00001e 9518                          reti
                                 .org 0x0020
000020 9518                          reti
                                 .org 0x0022
000022 9518                          reti
                                 .org 0x0024
000024 9518                          reti
                                 .org 0x0026
000026 9518                          reti
                                 .org 0x0028
000028 9518                          reti
                                 .org 0x002A
00002a 9518                          reti
                                 .org 0x002C
00002c 9518                          reti
                                 .org 0x002E
00002e 9518                          reti
                                 .org 0x0030
000030 9518                          reti
                                 .org 0x0032
000032 9518                          reti
                                 
                                 ;========================================================
                                 ; Tabla 7 segmentos
                                 ; bit6..bit0 = A B C D E F G
                                 ;========================================================
                                 SEG_TABLE:
000033 307e
000034 796d
000035 5b33
000036 705f
000037 7b7f
000038 0000                          .db 0b1111110, 0b0110000, 0b1101101, 0b1111001, 0b0110011, 0b1011011, 0b1011111, 0b1110000, 0b1111111, 0b1111011, 0b0000000, 0b0000000 ; padding
                                 
                                 ;========================================================
                                 ; RESET
                                 ;========================================================
                                 RESET:
000039 e008                          ldi r16, high(RAMEND)
00003a bf0e                          out SPH, r16
00003b ef0f                          ldi r16, low(RAMEND)
00003c bf0d                          out SPL, r16
                                 
00003d 2411                          clr r1
                                 
                                     ; Valores iniciales
00003e e00c                          ldi r16, 12
00003f 9300 0100                     sts hour, r16
                                 
000041 2700                          clr r16
000042 9300 0101                     sts minute, r16
000044 9300 0102                     sts second, r16
                                 
000046 e001                          ldi r16, 1
000047 9300 0103                     sts day, r16
000049 9300 0104                     sts month, r16
                                 
00004b e006                          ldi r16, 6
00004c 9300 0105                     sts alarm_hour, r16
                                 
00004e 2700                          clr r16
00004f 9300 0106                     sts alarm_min, r16
000051 9300 0107                     sts current_view, r16
000053 9300 0108                     sts edit_mode, r16
000055 9300 0109                     sts blink_flag, r16
000057 9300 010a                     sts ms_count_l, r16
000059 9300 010b                     sts ms_count_h, r16
00005b 9300 010c                     sts halfsec_l, r16
00005d 9300 010d                     sts halfsec_h, r16
00005f 9300 010e                     sts scan_idx, r16
000061 9300 0113                     sts btn_locks, r16
000063 9300 0114                     sts btn_events, r16
000065 9300 0115                     sts alarm_ringing, r16
000067 9300 0116                     sts alarm_latched, r16
000069 9300 0117                     sts colon_on, r16
00006b 9300 0118                     sts aux_led, r16
00006d 9300 010f                     sts disp0, r16
00006f 9300 0110                     sts disp1, r16
000071 9300 0111                     sts disp2, r16
000073 9300 0112                     sts disp3, r16
                                 
                                     ; PORTB:
                                     ; PB5 = ":"
                                     ; PB4..PB0 = segmentos A..E
000075 e30f                          ldi r16, 0b00111111
000076 b904                          out DDRB, r16
                                 
                                     ; PORTD:
                                     ; PD7..PD6 = segmentos F,G
                                     ; PD5..PD2 = multiplexado
                                     ; PD1..PD0 libres
000077 ef0c                          ldi r16, 0b11111100
000078 b90a                          out DDRD, r16
000079 2700                          clr r16
00007a b90b                          out PORTD, r16
                                 
                                     ; PORTC:
                                     ; PC0..PC3 = botones entrada
                                     ; PC4 = LED salida
                                     ; PC5 = buzzer salida
00007b e300                          ldi r16, 0b00110000
00007c b907                          out DDRC, r16
                                 
                                     ; pull-up en PC0..PC3
00007d e00f                          ldi r16, 0b00001111
00007e b908                          out PORTC, r16
                                 
                                     ; Pin Change Interrupt solo en PORTC
00007f e002                          ldi r16, (1<<PCIE1)
000080 9300 0068                     sts PCICR, r16
                                 
000082 e00f                          ldi r16, (1<<PCINT8)|(1<<PCINT9)|(1<<PCINT10)|(1<<PCINT11)
000083 9300 006c                     sts PCMSK1, r16
                                 
                                     ; Timer0 CTC cada 1 ms
000085 e002                          ldi r16, (1<<WGM01)
000086 bd04                          out TCCR0A, r16
                                 
000087 e003                          ldi r16, (1<<CS01)|(1<<CS00)
000088 bd05                          out TCCR0B, r16
                                 
000089 ef09                          ldi r16, 249
00008a bd07                          out OCR0A, r16
                                 
00008b e002                          ldi r16, (1<<OCIE0A)
00008c 9300 006e                     sts TIMSK0, r16
                                 
00008e 9478                          sei
                                 
                                 MAIN_LOOP:
00008f d082                          rcall PROCESS_BUTTON_EVENTS
000090 d0f2                          rcall UPDATE_UI_STATE
000091 d111                          rcall BUILD_DISPLAY_BUFFER
000092 cffc                          rjmp MAIN_LOOP
                                 
                                 ;========================================================
                                 ; ISR TIMER0 COMPA - cada 1 ms
                                 ;========================================================
                                 ISR_TIMER0_COMPA:
000093 930f                          push r16
000094 b70f                          in   r16, SREG
000095 930f                          push r16
000096 931f                          push r17
000097 932f                          push r18
000098 933f                          push r19
000099 934f                          push r20
00009a 935f                          push r21
00009b 936f                          push r22
00009c 937f                          push r23
00009d 938f                          push r24
00009e 939f                          push r25
00009f 93ef                          push r30
0000a0 93ff                          push r31
                                 
                                     ; contador de 500 ms
0000a1 9180 010c                     lds r24, halfsec_l
0000a3 9190 010d                     lds r25, halfsec_h
0000a5 9601                          adiw r24, 1
0000a6 9380 010c                     sts halfsec_l, r24
0000a8 9390 010d                     sts halfsec_h, r25
                                 
0000aa ef04                          ldi r16, low(500)
0000ab e011                          ldi r17, high(500)
0000ac 1780                          cp  r24, r16
0000ad 0791                          cpc r25, r17
0000ae f459                          brne T0_SKIP_500
                                 
0000af 2700                          clr r16
0000b0 9300 010c                     sts halfsec_l, r16
0000b2 9300 010d                     sts halfsec_h, r16
                                 
0000b4 9100 0109                     lds r16, blink_flag
0000b6 e011                          ldi r17, 1
0000b7 2701                          eor r16, r17
0000b8 9300 0109                     sts blink_flag, r16
                                 
                                 T0_SKIP_500:
                                     ; contador de 1000 ms
0000ba 9180 010a                     lds r24, ms_count_l
0000bc 9190 010b                     lds r25, ms_count_h
0000be 9601                          adiw r24, 1
0000bf 9380 010a                     sts ms_count_l, r24
0000c1 9390 010b                     sts ms_count_h, r25
                                 
0000c3 ee08                          ldi r16, low(1000)
0000c4 e013                          ldi r17, high(1000)
0000c5 1780                          cp  r24, r16
0000c6 0791                          cpc r25, r17
0000c7 f431                          brne T0_SKIP_1S
                                 
0000c8 2700                          clr r16
0000c9 9300 010a                     sts ms_count_l, r16
0000cb 9300 010b                     sts ms_count_h, r16
                                 
0000cd d18d                          rcall CLOCK_TICK_1S
                                 
                                 T0_SKIP_1S:
0000ce d145                          rcall MUX_REFRESH
                                 
0000cf 91ff                          pop r31
0000d0 91ef                          pop r30
0000d1 919f                          pop r25
0000d2 918f                          pop r24
0000d3 917f                          pop r23
0000d4 916f                          pop r22
0000d5 915f                          pop r21
0000d6 914f                          pop r20
0000d7 913f                          pop r19
0000d8 912f                          pop r18
0000d9 911f                          pop r17
0000da 910f                          pop r16
0000db bf0f                          out SREG, r16
0000dc 910f                          pop r16
0000dd 9518                          reti
                                 
                                 ;========================================================
                                 ; ISR PCINT1 para A0..A3
                                 ; Genera evento al soltar el botón
                                 ;========================================================
                                 ISR_PCINT1:
0000de 930f                          push r16
0000df b70f                          in   r16, SREG
0000e0 930f                          push r16
0000e1 931f                          push r17
0000e2 932f                          push r18
                                 
0000e3 b106                          in  r16, PINC
0000e4 9110 0113                     lds r17, btn_locks
0000e6 9120 0114                     lds r18, btn_events
                                 
                                     ; PC0 VIEW
0000e8 ff00                          sbrs r16, 0
0000e9 c005                          rjmp PC0_PRESSED
                                 PC0_RELEASED:
0000ea ff10                          sbrs r17, BTN_VIEW_BIT
0000eb c004                          rjmp CHECK_PC1
0000ec 7f1e                          cbr r17, (1<<BTN_VIEW_BIT)
0000ed 6021                          sbr r18, (1<<BTN_VIEW_BIT)
0000ee c001                          rjmp CHECK_PC1
                                 PC0_PRESSED:
0000ef 6011                          sbr r17, (1<<BTN_VIEW_BIT)
                                 
                                 CHECK_PC1:
                                     ; PC1 UP
0000f0 ff01                          sbrs r16, 1
0000f1 c005                          rjmp PC1_PRESSED
                                 PC1_RELEASED:
0000f2 ff11                          sbrs r17, BTN_UP_BIT
0000f3 c004                          rjmp CHECK_PC2
0000f4 7f1d                          cbr r17, (1<<BTN_UP_BIT)
0000f5 6022                          sbr r18, (1<<BTN_UP_BIT)
0000f6 c001                          rjmp CHECK_PC2
                                 PC1_PRESSED:
0000f7 6012                          sbr r17, (1<<BTN_UP_BIT)
                                 
                                 CHECK_PC2:
                                     ; PC2 DOWN
0000f8 ff02                          sbrs r16, 2
0000f9 c005                          rjmp PC2_PRESSED
                                 PC2_RELEASED:
0000fa ff12                          sbrs r17, BTN_DOWN_BIT
0000fb c004                          rjmp CHECK_PC3
0000fc 7f1b                          cbr r17, (1<<BTN_DOWN_BIT)
0000fd 6024                          sbr r18, (1<<BTN_DOWN_BIT)
0000fe c001                          rjmp CHECK_PC3
                                 PC2_PRESSED:
0000ff 6014                          sbr r17, (1<<BTN_DOWN_BIT)
                                 
                                 CHECK_PC3:
                                     ; PC3 MODE
000100 ff03                          sbrs r16, 3
000101 c005                          rjmp PC3_PRESSED
                                 PC3_RELEASED:
000102 ff13                          sbrs r17, BTN_MODE_BIT
000103 c004                          rjmp ISR_PC1_END
000104 7f17                          cbr r17, (1<<BTN_MODE_BIT)
000105 6028                          sbr r18, (1<<BTN_MODE_BIT)
000106 c001                          rjmp ISR_PC1_END
                                 PC3_PRESSED:
000107 6018                          sbr r17, (1<<BTN_MODE_BIT)
                                 
                                 ISR_PC1_END:
000108 9310 0113                     sts btn_locks, r17
00010a 9320 0114                     sts btn_events, r18
                                 
00010c 912f                          pop r18
00010d 911f                          pop r17
00010e 910f                          pop r16
00010f bf0f                          out SREG, r16
000110 910f                          pop r16
000111 9518                          reti
                                 
                                 ;========================================================
                                 ; Procesar eventos de botones
                                 ;========================================================
                                 PROCESS_BUTTON_EVENTS:
000112 930f                          push r16
000113 931f                          push r17
                                 
000114 9100 0114                     lds r16, btn_events
000116 2300                          tst r16
000117 f109                          breq PBE_EXIT
                                 
                                     ; MODE
000118 ff03                          sbrs r16, BTN_MODE_BIT
000119 c005                          rjmp PBE_CHECK_VIEW
00011a 7f07                          cbr r16, (1<<BTN_MODE_BIT)
00011b 9300 0114                     sts btn_events, r16
00011d d01e                          rcall HANDLE_MODE_EVENT
00011e c01a                          rjmp PBE_EXIT
                                 
                                 PBE_CHECK_VIEW:
00011f 9100 0114                     lds r16, btn_events
000121 ff00                          sbrs r16, BTN_VIEW_BIT
000122 c005                          rjmp PBE_CHECK_UP
000123 7f0e                          cbr r16, (1<<BTN_VIEW_BIT)
000124 9300 0114                     sts btn_events, r16
000126 d04d                          rcall HANDLE_VIEW_EVENT
000127 c011                          rjmp PBE_EXIT
                                 
                                 PBE_CHECK_UP:
000128 9100 0114                     lds r16, btn_events
00012a ff01                          sbrs r16, BTN_UP_BIT
00012b c005                          rjmp PBE_CHECK_DOWN
00012c 7f0d                          cbr r16, (1<<BTN_UP_BIT)
00012d 9300 0114                     sts btn_events, r16
00012f d17c                          rcall INCREMENT_ACTIVE_FIELD
000130 c008                          rjmp PBE_EXIT
                                 
                                 PBE_CHECK_DOWN:
000131 9100 0114                     lds r16, btn_events
000133 ff02                          sbrs r16, BTN_DOWN_BIT
000134 c004                          rjmp PBE_EXIT
000135 7f0b                          cbr r16, (1<<BTN_DOWN_BIT)
000136 9300 0114                     sts btn_events, r16
000138 d1ca                          rcall DECREMENT_ACTIVE_FIELD
                                 
                                 PBE_EXIT:
000139 911f                          pop r17
00013a 910f                          pop r16
00013b 9508                          ret
                                 
                                 ;========================================================
                                 ; Manejo botón MODE
                                 ;========================================================
                                 HANDLE_MODE_EVENT:
00013c 930f                          push r16
00013d 931f                          push r17
                                 
                                     ; si la alarma está sonando, MODE la silencia
00013e 9100 0115                     lds r16, alarm_ringing
000140 2300                          tst r16
000141 f021                          breq HME_NEXT_MODE
000142 2700                          clr r16
000143 9300 0115                     sts alarm_ringing, r16
000145 c02b                          rjmp HME_END
                                 
                                 HME_NEXT_MODE:
000146 9100 0108                     lds r16, edit_mode
000148 9503                          inc r16
000149 3007                          cpi r16, 7
00014a f008                          brlo HME_STORE
00014b 2700                          clr r16
                                 
                                 HME_STORE:
00014c 9300 0108                     sts edit_mode, r16
                                 
00014e 3001                          cpi r16, MODE_SET_HOUR
00014f f421                          brne HME_CHK1
000150 e010                          ldi r17, VIEW_TIME
000151 9310 0107                     sts current_view, r17
000153 c01d                          rjmp HME_END
                                 
                                 HME_CHK1:
000154 3002                          cpi r16, MODE_SET_MIN
000155 f421                          brne HME_CHK2
000156 e010                          ldi r17, VIEW_TIME
000157 9310 0107                     sts current_view, r17
000159 c017                          rjmp HME_END
                                 
                                 HME_CHK2:
00015a 3003                          cpi r16, MODE_SET_DAY
00015b f421                          brne HME_CHK3
00015c e011                          ldi r17, VIEW_DATE
00015d 9310 0107                     sts current_view, r17
00015f c011                          rjmp HME_END
                                 
                                 HME_CHK3:
000160 3004                          cpi r16, MODE_SET_MON
000161 f421                          brne HME_CHK4
000162 e011                          ldi r17, VIEW_DATE
000163 9310 0107                     sts current_view, r17
000165 c00b                          rjmp HME_END
                                 
                                 HME_CHK4:
000166 3005                          cpi r16, MODE_SET_AH
000167 f421                          brne HME_CHK5
000168 e012                          ldi r17, VIEW_ALARM
000169 9310 0107                     sts current_view, r17
00016b c005                          rjmp HME_END
                                 
                                 HME_CHK5:
00016c 3006                          cpi r16, MODE_SET_AM
00016d f419                          brne HME_END
00016e e012                          ldi r17, VIEW_ALARM
00016f 9310 0107                     sts current_view, r17
                                 
                                 HME_END:
000171 911f                          pop r17
000172 910f                          pop r16
000173 9508                          ret
                                 
                                 ;========================================================
                                 ; Manejo botón VIEW
                                 ;========================================================
                                 HANDLE_VIEW_EVENT:
000174 930f                          push r16
                                 
                                     ; solo cambia vista en modo normal
000175 9100 0108                     lds r16, edit_mode
000177 2300                          tst r16
000178 f441                          brne HVE_END
                                 
000179 9100 0107                     lds r16, current_view
00017b 9503                          inc r16
00017c 3003                          cpi r16, 3
00017d f008                          brlo HVE_STORE
00017e 2700                          clr r16
                                 
                                 HVE_STORE:
00017f 9300 0107                     sts current_view, r16
                                 
                                 HVE_END:
000181 910f                          pop r16
000182 9508                          ret
                                 
                                 ;========================================================
                                 ; Actualizar LEDs
                                 ;========================================================
                                 UPDATE_UI_STATE:
000183 930f                          push r16
000184 931f                          push r17
                                 
                                     ; ":" en D13
000185 9100 0107                     lds r16, current_view
000187 3001                          cpi r16, VIEW_DATE
000188 f421                          brne UIS_NOT_DATE
000189 e011                          ldi r17, 1
00018a 9310 0117                     sts colon_on, r17
00018c c004                          rjmp UIS_AUX
                                 
                                 UIS_NOT_DATE:
00018d 9110 0109                     lds r17, blink_flag
00018f 9310 0117                     sts colon_on, r17
                                 
                                 UIS_AUX:
                                     ; A4 encendido en vista alarma o config alarma
000191 2711                          clr r17
                                 
000192 9100 0107                     lds r16, current_view
000194 3002                          cpi r16, VIEW_ALARM
000195 f039                          breq UIS_AUX_ON
                                 
000196 9100 0108                     lds r16, edit_mode
000198 3005                          cpi r16, MODE_SET_AH
000199 f019                          breq UIS_AUX_ON
00019a 3006                          cpi r16, MODE_SET_AM
00019b f009                          breq UIS_AUX_ON
00019c c001                          rjmp UIS_STORE
                                 
                                 UIS_AUX_ON:
00019d e011                          ldi r17, 1
                                 
                                 UIS_STORE:
00019e 9310 0118                     sts aux_led, r17
                                 
0001a0 911f                          pop r17
0001a1 910f                          pop r16
0001a2 9508                          ret
                                 
                                 ;========================================================
                                 ; Construir buffer de display
                                 ;========================================================
                                 BUILD_DISPLAY_BUFFER:
0001a3 930f                          push r16
0001a4 931f                          push r17
0001a5 932f                          push r18
0001a6 933f                          push r19
0001a7 934f                          push r20
0001a8 935f                          push r21
0001a9 938f                          push r24
0001aa 939f                          push r25
0001ab 93ef                          push r30
0001ac 93ff                          push r31
                                 
                                     ; r16 = valor izquierdo
                                     ; r17 = valor derecho
0001ad 9100 0107                     lds r16, current_view
0001af 3000                          cpi r16, VIEW_TIME
0001b0 f429                          brne BDB_CHECK_DATE
0001b1 9100 0100                     lds r16, hour
0001b3 9110 0101                     lds r17, minute
0001b5 c00d                          rjmp BDB_SPLIT_PAIR
                                 
                                 BDB_CHECK_DATE:
0001b6 9120 0107                     lds r18, current_view
0001b8 3021                          cpi r18, VIEW_DATE
0001b9 f429                          brne BDB_LOAD_ALARM
0001ba 9100 0103                     lds r16, day
0001bc 9110 0104                     lds r17, month
0001be c004                          rjmp BDB_SPLIT_PAIR
                                 
                                 BDB_LOAD_ALARM:
0001bf 9100 0105                     lds r16, alarm_hour
0001c1 9110 0106                     lds r17, alarm_min
                                 
                                 BDB_SPLIT_PAIR:
0001c3 2f80                          mov r24, r16
0001c4 d039                          rcall SPLIT_DECIMAL
0001c5 2f28                          mov r18, r24
0001c6 2f39                          mov r19, r25
                                 
0001c7 2f81                          mov r24, r17
0001c8 d035                          rcall SPLIT_DECIMAL
0001c9 2f48                          mov r20, r24
0001ca 2f59                          mov r21, r25
                                 
                                     ; Parpadeo del campo en edición
0001cb 9100 0109                     lds r16, blink_flag
0001cd 2300                          tst r16
0001ce f4a1                          brne BDB_CONVERT
                                 
0001cf 9100 0108                     lds r16, edit_mode
0001d1 3001                          cpi r16, MODE_SET_HOUR
0001d2 f059                          breq BDB_BLANK_LEFT
0001d3 3003                          cpi r16, MODE_SET_DAY
0001d4 f049                          breq BDB_BLANK_LEFT
0001d5 3005                          cpi r16, MODE_SET_AH
0001d6 f039                          breq BDB_BLANK_LEFT
0001d7 3002                          cpi r16, MODE_SET_MIN
0001d8 f041                          breq BDB_BLANK_RIGHT
0001d9 3004                          cpi r16, MODE_SET_MON
0001da f031                          breq BDB_BLANK_RIGHT
0001db 3006                          cpi r16, MODE_SET_AM
0001dc f021                          breq BDB_BLANK_RIGHT
0001dd c005                          rjmp BDB_CONVERT
                                 
                                 BDB_BLANK_LEFT:
0001de e02a                          ldi r18, BLANK_CODE
0001df e03a                          ldi r19, BLANK_CODE
0001e0 c002                          rjmp BDB_CONVERT
                                 
                                 BDB_BLANK_RIGHT:
0001e1 e04a                          ldi r20, BLANK_CODE
0001e2 e05a                          ldi r21, BLANK_CODE
                                 
                                 BDB_CONVERT:
0001e3 2f82                          mov r24, r18
0001e4 d025                          rcall DIGIT_TO_SEG
0001e5 9380 010f                     sts disp0, r24
                                 
0001e7 2f83                          mov r24, r19
0001e8 d021                          rcall DIGIT_TO_SEG
0001e9 9380 0110                     sts disp1, r24
                                 
0001eb 2f84                          mov r24, r20
0001ec d01d                          rcall DIGIT_TO_SEG
0001ed 9380 0111                     sts disp2, r24
                                 
0001ef 2f85                          mov r24, r21
0001f0 d019                          rcall DIGIT_TO_SEG
0001f1 9380 0112                     sts disp3, r24
                                 
0001f3 91ff                          pop r31
0001f4 91ef                          pop r30
0001f5 919f                          pop r25
0001f6 918f                          pop r24
0001f7 915f                          pop r21
0001f8 914f                          pop r20
0001f9 913f                          pop r19
0001fa 912f                          pop r18
0001fb 911f                          pop r17
0001fc 910f                          pop r16
0001fd 9508                          ret
                                 
                                 ;========================================================
                                 ; Separar decimal
                                 ; Entrada: r24 = 0..99
                                 ; Salida:  r24 = decenas, r25 = unidades
                                 ;========================================================
                                 SPLIT_DECIMAL:
0001fe 930f                          push r16
0001ff 2700                          clr r16
000200 2799                          clr r25
                                 
                                 SPLIT_LOOP:
000201 308a                          cpi r24, 10
000202 f018                          brlo SPLIT_DONE
000203 508a                          subi r24, 10
000204 9503                          inc r16
000205 cffb                          rjmp SPLIT_LOOP
                                 
                                 SPLIT_DONE:
000206 2f98                          mov r25, r24
000207 2f80                          mov r24, r16
000208 910f                          pop r16
000209 9508                          ret
                                 
                                 ;========================================================
                                 ; Convertir dígito a segmentos
                                 ; Entrada: r24 = 0..10
                                 ; Salida:  r24 = patrón 7 segmentos
                                 ;========================================================
                                 DIGIT_TO_SEG:
00020a 93ff                          push ZH
00020b 93ef                          push ZL
00020c e0f0                          ldi ZH, high(SEG_TABLE<<1)
00020d e6e6                          ldi ZL, low(SEG_TABLE<<1)
00020e 0fe8                          add ZL, r24
00020f 1df1                          adc ZH, r1
000210 9184                          lpm r24, Z
000211 91ef                          pop ZL
000212 91ff                          pop ZH
000213 9508                          ret
                                 
                                 ;========================================================
                                 ; Multiplexado
                                 ; D5 = decenas horas/día
                                 ; D4 = unidades horas/día
                                 ; D3 = decenas minutos/mes
                                 ; D2 = unidades minutos/mes
                                 ;========================================================
                                 MUX_REFRESH:
000214 930f                          push r16
000215 931f                          push r17
000216 932f                          push r18
000217 933f                          push r19
000218 934f                          push r20
                                 
000219 9100 010e                     lds r16, scan_idx
                                 
00021b 3000                          cpi r16, 0
00021c f421                          brne MUX_CHK1
00021d 9110 010f                     lds r17, disp0
00021f e220                          ldi r18, (1<<PD5)
000220 c00f                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK1:
000221 3001                          cpi r16, 1
000222 f421                          brne MUX_CHK2
000223 9110 0110                     lds r17, disp1
000225 e120                          ldi r18, (1<<PD4)
000226 c009                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK2:
000227 3002                          cpi r16, 2
000228 f421                          brne MUX_CHK3
000229 9110 0111                     lds r17, disp2
00022b e028                          ldi r18, (1<<PD3)
00022c c003                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK3:
00022d 9110 0112                     lds r17, disp3
00022f e024                          ldi r18, (1<<PD2)
                                 
                                 MUX_OUTPUT:
                                     ; PORTB = ":" + segmentos A..E
000230 2f31                          mov r19, r17
000231 9536                          lsr r19
000232 9536                          lsr r19
000233 713f                          andi r19, 0b00011111
                                 
000234 9140 0117                     lds r20, colon_on
000236 2344                          tst r20
000237 f009                          breq MUX_NO_COLON
000238 6230                          ori r19, (1<<PB5)
                                 
                                 MUX_NO_COLON:
000239 b935                          out PORTB, r19
                                 
                                     ; PORTD = segmentos F/G + dígito activo
00023a 2733                          clr r19
00023b fd11                          sbrc r17, 1
00023c 6830                          ori r19, (1<<PD7)
00023d fd10                          sbrc r17, 0
00023e 6430                          ori r19, (1<<PD6)
00023f 2b32                          or  r19, r18
000240 b93b                          out PORTD, r19
                                 
                                     ; PORTC = pull-ups PC0..PC3 + LED A4 + buzzer A5
000241 e03f                          ldi r19, 0b00001111
                                 
000242 9140 0118                     lds r20, aux_led
000244 2344                          tst r20
000245 f009                          breq MUX_NO_AUX
000246 6130                          ori r19, (1<<PC4)
                                 
                                 MUX_NO_AUX:
000247 9140 0115                     lds r20, alarm_ringing
000249 2344                          tst r20
00024a f009                          breq MUX_NO_BUZZ
00024b 6230                          ori r19, (1<<PC5)
                                 
                                 MUX_NO_BUZZ:
00024c b938                          out PORTC, r19
                                 
00024d 9100 010e                     lds r16, scan_idx
00024f 9503                          inc r16
000250 3004                          cpi r16, 4
000251 f008                          brlo MUX_STORE
000252 2700                          clr r16
                                 
                                 MUX_STORE:
000253 9300 010e                     sts scan_idx, r16
                                 
000255 914f                          pop r20
000256 913f                          pop r19
000257 912f                          pop r18
000258 911f                          pop r17
000259 910f                          pop r16
00025a 9508                          ret
                                 
                                 ;========================================================
                                 ; Tick de 1 segundo
                                 ;========================================================
                                 CLOCK_TICK_1S:
00025b 930f                          push r16
00025c 931f                          push r17
                                 
00025d 9100 0102                     lds r16, second
00025f 9503                          inc r16
000260 330c                          cpi r16, 60
000261 f0d8                          brlo CTS_STORE_SEC
                                 
000262 2700                          clr r16
000263 9300 0102                     sts second, r16
                                 
000265 9100 0101                     lds r16, minute
000267 9503                          inc r16
000268 330c                          cpi r16, 60
000269 f080                          brlo CTS_STORE_MIN
                                 
00026a 2700                          clr r16
00026b 9300 0101                     sts minute, r16
                                 
00026d 9100 0100                     lds r16, hour
00026f 9503                          inc r16
000270 3108                          cpi r16, 24
000271 f028                          brlo CTS_STORE_HOUR
                                 
000272 2700                          clr r16
000273 9300 0100                     sts hour, r16
000275 d0e9                          rcall INCREMENT_DAY_ROLLOVER
000276 c008                          rjmp CTS_ALARM_CHECK
                                 
                                 CTS_STORE_HOUR:
000277 9300 0100                     sts hour, r16
000279 c005                          rjmp CTS_ALARM_CHECK
                                 
                                 CTS_STORE_MIN:
00027a 9300 0101                     sts minute, r16
00027c c002                          rjmp CTS_ALARM_CHECK
                                 
                                 CTS_STORE_SEC:
00027d 9300 0102                     sts second, r16
                                 
                                 CTS_ALARM_CHECK:
                                     ; activar solo al inicio del minuto exacto
00027f 9100 0102                     lds r16, second
000281 2300                          tst r16
000282 f4b1                          brne CTS_CLEAR_IF_NEEDED
                                 
000283 9100 0100                     lds r16, hour
000285 9110 0105                     lds r17, alarm_hour
000287 1701                          cp  r16, r17
000288 f481                          brne CTS_CLEAR_IF_NEEDED
                                 
000289 9100 0101                     lds r16, minute
00028b 9110 0106                     lds r17, alarm_min
00028d 1701                          cp  r16, r17
00028e f451                          brne CTS_CLEAR_IF_NEEDED
                                 
00028f 9100 0116                     lds r16, alarm_latched
000291 2300                          tst r16
000292 f4b1                          brne CTS_END
                                 
000293 e001                          ldi r16, 1
000294 9300 0115                     sts alarm_ringing, r16
000296 9300 0116                     sts alarm_latched, r16
000298 c010                          rjmp CTS_END
                                 
                                 CTS_CLEAR_IF_NEEDED:
000299 9100 0100                     lds r16, hour
00029b 9110 0105                     lds r17, alarm_hour
00029d 1701                          cp  r16, r17
00029e f439                          brne CTS_CLEAR_LATCH
                                 
00029f 9100 0101                     lds r16, minute
0002a1 9110 0106                     lds r17, alarm_min
0002a3 1701                          cp  r16, r17
0002a4 f409                          brne CTS_CLEAR_LATCH
                                 
0002a5 c003                          rjmp CTS_END
                                 
                                 CTS_CLEAR_LATCH:
0002a6 2700                          clr r16
0002a7 9300 0116                     sts alarm_latched, r16
                                 
                                 CTS_END:
0002a9 911f                          pop r17
0002aa 910f                          pop r16
0002ab 9508                          ret
                                 
                                 ;========================================================
                                 ; Incrementar campo activo
                                 ;========================================================
                                 INCREMENT_ACTIVE_FIELD:
0002ac 930f                          push r16
0002ad 931f                          push r17
0002ae 932f                          push r18
                                 
0002af 9100 0108                     lds r16, edit_mode
                                 
0002b1 3001                          cpi r16, MODE_SET_HOUR
0002b2 f449                          brne IAF_CHK_MIN
0002b3 9110 0100                     lds r17, hour
0002b5 9513                          inc r17
0002b6 3118                          cpi r17, 24
0002b7 f008                          brlo IAF_STORE_HOUR
0002b8 2711                          clr r17
                                 IAF_STORE_HOUR:
0002b9 9310 0100                     sts hour, r17
0002bb c043                          rjmp IAF_END
                                 
                                 IAF_CHK_MIN:
0002bc 3002                          cpi r16, MODE_SET_MIN
0002bd f461                          brne IAF_CHK_DAY
0002be 9110 0101                     lds r17, minute
0002c0 9513                          inc r17
0002c1 331c                          cpi r17, 60
0002c2 f008                          brlo IAF_STORE_MIN
0002c3 2711                          clr r17
                                 IAF_STORE_MIN:
0002c4 9310 0101                     sts minute, r17
0002c6 2711                          clr r17
0002c7 9310 0102                     sts second, r17
0002c9 c035                          rjmp IAF_END
                                 
                                 IAF_CHK_DAY:
0002ca 3003                          cpi r16, MODE_SET_DAY
0002cb f459                          brne IAF_CHK_MON
0002cc 9110 0103                     lds r17, day
0002ce 9513                          inc r17
0002cf d0ab                          rcall GET_MONTH_MAXDAY
0002d0 1712                          cp r17, r18
0002d1 f010                          brlo IAF_STORE_DAY
0002d2 f009                          breq IAF_STORE_DAY
0002d3 e011                          ldi r17, 1
                                 IAF_STORE_DAY:
0002d4 9310 0103                     sts day, r17
0002d6 c028                          rjmp IAF_END
                                 
                                 IAF_CHK_MON:
0002d7 3004                          cpi r16, MODE_SET_MON
0002d8 f489                          brne IAF_CHK_AH
0002d9 9110 0104                     lds r17, month
0002db 9513                          inc r17
0002dc 301d                          cpi r17, 13
0002dd f008                          brlo IAF_STORE_MON
0002de e011                          ldi r17, 1
                                 IAF_STORE_MON:
0002df 9310 0104                     sts month, r17
0002e1 9110 0103                     lds r17, day
0002e3 d097                          rcall GET_MONTH_MAXDAY
0002e4 1712                          cp r17, r18
0002e5 f0c8                          brlo IAF_END
0002e6 f0c1                          breq IAF_END
0002e7 9320 0103                     sts day, r18
0002e9 c015                          rjmp IAF_END
                                 
                                 IAF_CHK_AH:
0002ea 3005                          cpi r16, MODE_SET_AH
0002eb f449                          brne IAF_CHK_AM
0002ec 9110 0105                     lds r17, alarm_hour
0002ee 9513                          inc r17
0002ef 3118                          cpi r17, 24
0002f0 f008                          brlo IAF_STORE_AH
0002f1 2711                          clr r17
                                 IAF_STORE_AH:
0002f2 9310 0105                     sts alarm_hour, r17
0002f4 c00a                          rjmp IAF_END
                                 
                                 IAF_CHK_AM:
0002f5 3006                          cpi r16, MODE_SET_AM
0002f6 f441                          brne IAF_END
0002f7 9110 0106                     lds r17, alarm_min
0002f9 9513                          inc r17
0002fa 331c                          cpi r17, 60
0002fb f008                          brlo IAF_STORE_AM
0002fc 2711                          clr r17
                                 IAF_STORE_AM:
0002fd 9310 0106                     sts alarm_min, r17
                                 
                                 IAF_END:
0002ff 912f                          pop r18
000300 911f                          pop r17
000301 910f                          pop r16
000302 9508                          ret
                                 
                                 ;========================================================
                                 ; Decrementar campo activo
                                 ;========================================================
                                 DECREMENT_ACTIVE_FIELD:
000303 930f                          push r16
000304 931f                          push r17
000305 932f                          push r18
                                 
000306 9100 0108                     lds r16, edit_mode
                                 
000308 3001                          cpi r16, MODE_SET_HOUR
000309 f451                          brne DAF_CHK_MIN
00030a 9110 0100                     lds r17, hour
00030c 2311                          tst r17
00030d f411                          brne DAF_DEC_HOUR
00030e e117                          ldi r17, 23
00030f c001                          rjmp DAF_STORE_HOUR
                                 DAF_DEC_HOUR:
000310 951a                          dec r17
                                 DAF_STORE_HOUR:
000311 9310 0100                     sts hour, r17
000313 c047                          rjmp DAF_END
                                 
                                 DAF_CHK_MIN:
000314 3002                          cpi r16, MODE_SET_MIN
000315 f469                          brne DAF_CHK_DAY
000316 9110 0101                     lds r17, minute
000318 2311                          tst r17
000319 f411                          brne DAF_DEC_MIN
00031a e31b                          ldi r17, 59
00031b c001                          rjmp DAF_STORE_MIN
                                 DAF_DEC_MIN:
00031c 951a                          dec r17
                                 DAF_STORE_MIN:
00031d 9310 0101                     sts minute, r17
00031f 2711                          clr r17
000320 9310 0102                     sts second, r17
000322 c038                          rjmp DAF_END
                                 
                                 DAF_CHK_DAY:
000323 3003                          cpi r16, MODE_SET_DAY
000324 f459                          brne DAF_CHK_MON
000325 9110 0103                     lds r17, day
000327 3011                          cpi r17, 1
000328 f419                          brne DAF_DEC_DAY
000329 d051                          rcall GET_MONTH_MAXDAY
00032a 2f12                          mov r17, r18
00032b c001                          rjmp DAF_STORE_DAY
                                 DAF_DEC_DAY:
00032c 951a                          dec r17
                                 DAF_STORE_DAY:
00032d 9310 0103                     sts day, r17
00032f c02b                          rjmp DAF_END
                                 
                                 DAF_CHK_MON:
000330 3004                          cpi r16, MODE_SET_MON
000331 f491                          brne DAF_CHK_AH
000332 9110 0104                     lds r17, month
000334 3011                          cpi r17, 1
000335 f411                          brne DAF_DEC_MON
000336 e01c                          ldi r17, 12
000337 c001                          rjmp DAF_STORE_MON
                                 DAF_DEC_MON:
000338 951a                          dec r17
                                 DAF_STORE_MON:
000339 9310 0104                     sts month, r17
00033b 9110 0103                     lds r17, day
00033d d03d                          rcall GET_MONTH_MAXDAY
00033e 1712                          cp r17, r18
00033f f0d8                          brlo DAF_END
000340 f0d1                          breq DAF_END
000341 9320 0103                     sts day, r18
000343 c017                          rjmp DAF_END
                                 
                                 DAF_CHK_AH:
000344 3005                          cpi r16, MODE_SET_AH
000345 f451                          brne DAF_CHK_AM
000346 9110 0105                     lds r17, alarm_hour
000348 2311                          tst r17
000349 f411                          brne DAF_DEC_AH
00034a e117                          ldi r17, 23
00034b c001                          rjmp DAF_STORE_AH
                                 DAF_DEC_AH:
00034c 951a                          dec r17
                                 DAF_STORE_AH:
00034d 9310 0105                     sts alarm_hour, r17
00034f c00b                          rjmp DAF_END
                                 
                                 DAF_CHK_AM:
000350 3006                          cpi r16, MODE_SET_AM
000351 f449                          brne DAF_END
000352 9110 0106                     lds r17, alarm_min
000354 2311                          tst r17
000355 f411                          brne DAF_DEC_AM
000356 e31b                          ldi r17, 59
000357 c001                          rjmp DAF_STORE_AM
                                 DAF_DEC_AM:
000358 951a                          dec r17
                                 DAF_STORE_AM:
000359 9310 0106                     sts alarm_min, r17
                                 
                                 DAF_END:
00035b 912f                          pop r18
00035c 911f                          pop r17
00035d 910f                          pop r16
00035e 9508                          ret
                                 
                                 ;========================================================
                                 ; Avance natural del día
                                 ;========================================================
                                 INCREMENT_DAY_ROLLOVER:
00035f 930f                          push r16
000360 931f                          push r17
000361 932f                          push r18
                                 
000362 9100 0103                     lds r16, day
000364 9503                          inc r16
                                 
000365 d015                          rcall GET_MONTH_MAXDAY
000366 1702                          cp r16, r18
000367 f068                          brlo IDR_STORE_DAY
000368 f061                          breq IDR_STORE_DAY
                                 
000369 e001                          ldi r16, 1
00036a 9300 0103                     sts day, r16
                                 
00036c 9110 0104                     lds r17, month
00036e 9513                          inc r17
00036f 301d                          cpi r17, 13
000370 f008                          brlo IDR_STORE_MONTH
000371 e011                          ldi r17, 1
                                 
                                 IDR_STORE_MONTH:
000372 9310 0104                     sts month, r17
000374 c002                          rjmp IDR_END
                                 
                                 IDR_STORE_DAY:
000375 9300 0103                     sts day, r16
                                 
                                 IDR_END:
000377 912f                          pop r18
000378 911f                          pop r17
000379 910f                          pop r16
00037a 9508                          ret
                                 
                                 ;========================================================
                                 ; r18 = máximo día del mes actual
