000309 f459                          brne DC_MES
00030a 9110 0103                     lds r17, dia
00030c 3011                          cpi r17, 1
00030d f419                          brne DC_DEC_DIA
00030e d051                          rcall MAX_DIAS_MES
00030f 2f12                          mov r17, r18
000310 c001                          rjmp DC_GUARDAR_DIA
                                 DC_DEC_DIA:
