                                 DC_FIN:
000340 912f                          pop r18
000341 911f                          pop r17
000342 910f                          pop r16
000343 9508                          ret
                                 
                                 
                                 ; avanza el dia del calendario al llegar a medianoche
                                 AVANZAR_DIA:
000344 930f                          push r16
000345 931f                          push r17
000346 932f                          push r18
                                 
000347 9100 0103                     lds r16, dia
000349 9503                          inc r16
                                 
00034a d015                          rcall MAX_DIAS_MES
00034b 1702                          cp r16, r18
00034c f068                          brlo ADR_GUARDAR_DIA
00034d f061                          breq ADR_GUARDAR_DIA
                                 
                                     ; si se supero el maximo del mes pasar al dia uno del mes siguiente
00034e e001                          ldi r16, 1
00034f 9300 0103                     sts dia, r16
                                 
