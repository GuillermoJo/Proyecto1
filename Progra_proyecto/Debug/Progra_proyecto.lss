000297 f449                          brne IC_MIN
000298 9110 0100                     lds r17, horas
00029a 9513                          inc r17
00029b 3118                          cpi r17, 24
00029c f008                          brlo IC_GUARDAR_HORA
00029d 2711                          clr r17
                                 IC_GUARDAR_HORA:
00029e 9310 0100                     sts horas, r17
0002a0 c043                          rjmp IC_FIN
                                 
                                 IC_MIN:
0002a1 3002                          cpi r16, MODO_MINUTO
0002a2 f461                          brne IC_DIA
0002a3 9110 0101                     lds r17, minutos
0002a5 9513                          inc r17
0002a6 331c                          cpi r17, 60
0002a7 f008                          brlo IC_GUARDAR_MIN
0002a8 2711                          clr r17
                                 IC_GUARDAR_MIN:
0002a9 9310 0101                     sts minutos, r17
0002ab 2711                          clr r17
0002ac 9310 0102                     sts segundos, r17
0002ae c035                          rjmp IC_FIN
                                 
                                 IC_DIA:
0002af 3003                          cpi r16, MODO_DIA
0002b0 f459                          brne IC_MES
0002b1 9110 0103                     lds r17, dia
0002b3 9513                          inc r17
0002b4 d0ab                          rcall MAX_DIAS_MES
0002b5 1712                          cp r17, r18
0002b6 f010                          brlo IC_GUARDAR_DIA
0002b7 f009                          breq IC_GUARDAR_DIA
0002b8 e011                          ldi r17, 1
                                 IC_GUARDAR_DIA:
0002b9 9310 0103                     sts dia, r17
0002bb c028                          rjmp IC_FIN
                                 
                                 IC_MES:
0002bc 3004                          cpi r16, MODO_MES
0002bd f489                          brne IC_ALAR_H
0002be 9110 0104                     lds r17, mes
0002c0 9513                          inc r17
0002c1 301d                          cpi r17, 13
0002c2 f008                          brlo IC_GUARDAR_MES
0002c3 e011                          ldi r17, 1
                                 IC_GUARDAR_MES:
0002c4 9310 0104                     sts mes, r17
0002c6 9110 0103                     lds r17, dia
0002c8 d097                          rcall MAX_DIAS_MES
0002c9 1712                          cp r17, r18
0002ca f0c8                          brlo IC_FIN
0002cb f0c1                          breq IC_FIN
0002cc 9320 0103                     sts dia, r18
0002ce c015                          rjmp IC_FIN
                                 
                                 IC_ALAR_H:
0002cf 3005                          cpi r16, MODO_ALARM_H
0002d0 f449                          brne IC_ALAR_M
0002d1 9110 0105                     lds r17, alar_hora
0002d3 9513                          inc r17
0002d4 3118                          cpi r17, 24
0002d5 f008                          brlo IC_GUARDAR_AH
0002d6 2711                          clr r17
                                 IC_GUARDAR_AH:
0002d7 9310 0105                     sts alar_hora, r17
0002d9 c00a                          rjmp IC_FIN
                                 
                                 IC_ALAR_M:
0002da 3006                          cpi r16, MODO_ALARM_M
0002db f441                          brne IC_FIN
0002dc 9110 0106                     lds r17, alar_min
0002de 9513                          inc r17
0002df 331c                          cpi r17, 60
0002e0 f008                          brlo IC_GUARDAR_AM
0002e1 2711                          clr r17
                                 IC_GUARDAR_AM:
0002e2 9310 0106                     sts alar_min, r17
                                 
                                 IC_FIN:
0002e4 912f                          pop r18
0002e5 911f                          pop r17
0002e6 910f                          pop r16
0002e7 9508                          ret
                                 
                                 
                                 ; decrementa el campo que esta siendo editado segun el modo activo
                                 DECREMENTAR_CAMPO:
