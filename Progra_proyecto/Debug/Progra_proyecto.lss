                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x100
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;24616
                                 ;Proyecto 1
                                 
                                 .include "m328pdef.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; Constantes con nombre para los modos de edición
                                 .equ MODE_NORMAL    = 0     ; Sin campo en edición
                                 .equ MODE_SET_HOUR  = 1     ; Editando horas del reloj
                                 .equ MODE_SET_MIN   = 2     ; Editando minutos del reloj
                                 .equ MODE_SET_DAY   = 3     ; Editando día del calendario
                                 .equ MODE_SET_MON   = 4     ; Editando mes del calendario
                                 .equ MODE_SET_AH    = 5     ; Editando hora de alarma
                                 .equ MODE_SET_AM    = 6     ; Editando minuto de alarma
                                 
                                 ; Constantes con nombre para las vistas del display
                                 .equ VIEW_TIME      = 0     ; Muestra HH:MM
                                 .equ VIEW_DATE      = 1     ; Muestra DD:MM
                                 .equ VIEW_ALARM     = 2     ; Muestra alarma HH:MM
                                 
                                 ; Posiciones de bit en los registros de estado de botones
                                 .equ BTN_VIEW_BIT   = 0
                                 .equ BTN_UP_BIT     = 1
                                 .equ BTN_DOWN_BIT   = 2
                                 .equ BTN_MODE_BIT   = 3
                                 
                                 ; Código de dígito, mapea a "todos los segmentos apagados" en SEG_TABLE
                                 .equ BLANK_CODE     = 10
                                 
                                 ; REGISTROS
                                 ; Todos los temporales
                                 .def rA   = r16
                                 .def rB   = r17     
                                 .def rC   = r18     
                                 .def rD   = r19     
                                 .def rE   = r20     
                                 .def rF   = r21     
                                 .def rG   = r22     
                                 .def rH   = r23     
                                 
                                 ;SEGMENTO DE DATOS EN SRAM
                                 .dseg
                                 
                                 ;Campos del reloj en tiempo real
000100                           hour:           .byte 1     ; 0..23
000101                           minute:         .byte 1     ; 0..59
000102                           second:         .byte 1     ; 0..59
                                 
                                 ;Campos del calendario
000103                           day:            .byte 1     ; 1..31
000104                           month:          .byte 1     ; 1..12
                                 
                                 ;Configuración de alarma
000105                           alarm_hour:     .byte 1     ; 0..23
000106                           alarm_min:      .byte 1     ; 0..59
                                 
                                 ;Estado
000107                           current_view:   .byte 1     ; VIEW_TIME / VIEW_DATE / VIEW_ALARM
000108                           edit_mode:      .byte 1     ; MODE_NORMAL .. MODE_SET_AM
                                 
                                 ;Auxiliares
000109                           blink_flag:     .byte 1     ; Se invierte cada 500 ms; controla parpadeo y colon
00010a                           ms_count_l:     .byte 1     ; Byte bajo del contador 0-999 ms
00010b                           ms_count_h:     .byte 1     ; Byte alto del contador 0-999 ms
00010c                           halfsec_l:      .byte 1     ; Byte bajo del contador 0-499 ms
00010d                           halfsec_h:      .byte 1     ; Byte alto del contador 0-499 ms
                                 
                                 ;Driver del display
00010e                           scan_idx:       .byte 1     ; Posición del dígito que se está manejando (0..3)
00010f                           disp0:          .byte 1     ; Patrón de segmentos para dígito 0 (más a la izquierda)
000110                           disp1:          .byte 1     ; Patrón de segmentos para dígito 1
000111                           disp2:          .byte 1     ; Patrón de segmentos para dígito 2
000112                           disp3:          .byte 1     ; Patrón de segmentos para dígito 3 (más a la derecha)
                                 
                                 ; Flags de control por evento de presionar y soltar
                                 ; btn_locks : bit activo mientras el botón está presionado (evita eventos repetidos)
                                 ; btn_events: bit activo en flanco de soltar; limpiado por PROCESS_BUTTON_EVENTS
000113                           btn_locks:      .byte 1
000114                           btn_events:     .byte 1
                                 
                                 ; Estado de la alarma
                                 ; alarm_ringing : 1 mientras el buzzer debe sonar; se limpia con el botón MODE
                                 ; alarm_latched : evita re-activación dentro del mismo minuto de alarma
000115                           alarm_ringing:  .byte 1
000116                           alarm_latched:  .byte 1
                                 
                                 ; Control de salidas
000117                           colon_on:   .byte 1     ; 1 = LED de dos puntos habilitado en este ciclo MUX
000118                           aux_led:    .byte 1     ; 1 = LED indicador de alarma habilitado
                                 
                                 ; SEGMENTO DE CÓDIGO
                                 .cseg
                                 
                                 
                                 ; Tabla de interrupciones
                                 ; Solo se usan dos vectores
                                 .org 0x0000
000000 c038                          rjmp RESET              ; Encendido / reset externo
                                 
                                 .org 0x0002
000002 9518                          reti
                                 .org 0x0004
000004 9518                          reti
                                 .org 0x0006
000006 9518                          reti
                                 .org 0x0008
000008 c0d6                          rjmp ISR_PCINT1         ; PCINT1 (pines PORTC) -> manejador de botones
                                 .org 0x000A
00000a 9518                          reti
                                 .org 0x000C
00000c 9518                          reti
                                 .org 0x000E
00000e 9518                          reti
                                 .org 0x0010
000010 9518                          reti
                                 .org 0x0012
000012 9518                          reti
                                 .org 0x0014
000014 9518                          reti
                                 .org 0x0016
000016 9518                          reti
                                 .org 0x0018
000018 9518                          reti
                                 .org 0x001A
00001a 9518                          reti
                                 .org 0x001C
00001c c077                          rjmp ISR_TIMER0_COMPA   ; TIMER0 COMPA -> tick de 1 ms
                                 .org 0x001E
00001e 9518                          reti
                                 .org 0x0020
000020 9518                          reti
                                 .org 0x0022
000022 9518                          reti
                                 .org 0x0024
000024 9518                          reti
                                 .org 0x0026
000026 9518                          reti
                                 .org 0x0028
000028 9518                          reti
                                 .org 0x002A
00002a 9518                          reti
                                 .org 0x002C
00002c 9518                          reti
                                 .org 0x002E
00002e 9518                          reti
                                 .org 0x0030
000030 9518                          reti
                                 .org 0x0032
000032 9518                          reti
                                 
                                 ; TABLA DE LOOKUP 7 SEGMENTOS
                                 SEG_TABLE:
000033 307e
000034 796d
000035 5b33
000036 705f
000037 7b7f
000038 0000                          .db 0b1111110, 0b0110000, 0b1101101, 0b1111001, 0b0110011, 0b1011011, 0b1011111, 0b1110000, 0b1111111, 0b1111011, 0b0000000, 0b0000000
                                 
                                 
                                 ; Se ejecuta una vez al encender o tras cualquier fuente de reset.
                                 RESET:
                                     ;Configuración del puntero
000039 e008                          ldi rA, high(RAMEND)
00003a bf0e                          out SPH, rA
00003b ef0f                          ldi rA, low(RAMEND)
00003c bf0d                          out SPL, rA
00003d 2411                          clr r1                  ; r1 se mantiene en 0
                                 
                                     ;Valores iniciales del reloj
00003e e00c                          ldi rA, 12
00003f 9300 0100                     sts hour, rA            ; Arranca en 12:00:00
000041 2700                          clr rA
000042 9300 0101                     sts minute, rA
000044 9300 0102                     sts second, rA
                                 
                                     ;Valores iniciales del calendario
000046 e001                          ldi rA, 1
000047 9300 0103                     sts day, rA             ; 1 de enero
000049 9300 0104                     sts month, rA
                                 
                                     ;Valores iniciales de la alarma
00004b e006                          ldi rA, 6
00004c 9300 0105                     sts alarm_hour, rA      ; Alarma por defecto a las 06:00
00004e 2700                          clr rA
00004f 9300 0106                     sts alarm_min, rA
                                 
                                     ;Poner en cero todas las variables de UI y control
000051 2700                          clr rA
000052 9300 0107                     sts current_view, rA
000054 9300 0108                     sts edit_mode, rA
000056 9300 0109                     sts blink_flag, rA
000058 9300 010a                     sts ms_count_l, rA
00005a 9300 010b                     sts ms_count_h, rA
00005c 9300 010c                     sts halfsec_l, rA
00005e 9300 010d                     sts halfsec_h, rA
000060 9300 010e                     sts scan_idx, rA
000062 9300 0113                     sts btn_locks, rA
000064 9300 0114                     sts btn_events, rA
000066 9300 0115                     sts alarm_ringing, rA
000068 9300 0116                     sts alarm_latched, rA
00006a 9300 0117                     sts colon_on, rA
00006c 9300 0118                     sts aux_led, rA
00006e 9300 010f                     sts disp0, rA
000070 9300 0110                     sts disp1, rA
000072 9300 0111                     sts disp2, rA
000074 9300 0112                     sts disp3, rA
                                 
                                     ;Registros de dirección de GPIO
                                     ; PORTB: PB0-PB5 todas salidas
000076 e30f                          ldi rA, 0b00111111
000077 b904                          out DDRB, rA
                                 
                                     ; PORTD: PD2-PD7 salidas
000078 ef0c                          ldi rA, 0b11111100
000079 b90a                          out DDRD, rA
                                 
                                     ; PORTD valor inicial
00007a 2700                          clr rA
00007b b90b                          out PORTD, rA
                                 
                                     ; PORTC: PC0-PC3 entradas, PC4 salida, PC5 salida
00007c e300                          ldi rA, 0b00110000
00007d b907                          out DDRC, rA
                                 
                                     ; Activar pull-ups internos en los pines de botones PC0-PC3
                                     ; El botón lee 0 cuando está presionado y 1 cuando está suelto
00007e e00f                          ldi rA, 0b00001111
00007f b908                          out PORTC, rA
                                 
                                     ;Configuración de interrupción por cambio de pin
                                     ; Habilitar PCIE1 para monitorear PORTC
000080 e002                          ldi rA, (1<<PCIE1)
000081 9300 0068                     sts PCICR, rA
                                 
                                     ; Desenmascarar solo PC0-PC3 dentro del grupo PORTC
000083 e00f                          ldi rA, (1<<PCINT8)|(1<<PCINT9)|(1<<PCINT10)|(1<<PCINT11)
000084 9300 006c                     sts PCMSK1, rA
                                 
                                     ;Configuración Timer0: CTC
                                     ; f_tick = 16.000.000 / (64 * (249+1)) = 1000 Hz  => período = 1 ms
000086 e002                          ldi rA, (1<<WGM01)          ; Modo CTC
000087 bd04                          out TCCR0A, rA
000088 e003                          ldi rA, (1<<CS01)|(1<<CS00) ; Prescaler = 64
000089 bd05                          out TCCR0B, rA
00008a ef09                          ldi rA, 249                 ; OCR0A = 249 -> comparación cada 1 ms
00008b bd07                          out OCR0A, rA
00008c e002                          ldi rA, (1<<OCIE0A)         ; Habilitar interrupción Output Compare A
00008d 9300 006e                     sts TIMSK0, rA
00008f 9478                          sei                         ; Habilitar interrupciones globales
                                 
                                 ; BUCLE PRINCIPAL
                                 MAIN_LOOP:
000090 d082                          rcall PROCESS_BUTTON_EVENTS ; Procesar eventos pendientes de botones soltados
000091 d0eb                          rcall UPDATE_UI_STATE       
000092 d10a                          rcall BUILD_DISPLAY_BUFFER  
000093 cffc                          rjmp  MAIN_LOOP
                                 
                                 ; ISR_TIMER0_COMPA  - Se dispara cada 1 ms
                                 ISR_TIMER0_COMPA:
000094 930f                          push r16
000095 b70f                          in   r16, SREG              ; Guardar registro de estado
000096 930f                          push r16
000097 931f                          push r17
000098 932f                          push r18
000099 933f                          push r19
00009a 934f                          push r20
00009b 935f                          push r21
00009c 936f                          push r22
00009d 937f                          push r23
00009e 938f                          push r24
00009f 939f                          push r25
0000a0 93ef                          push r30
0000a1 93ff                          push r31
                                 
                                     ;Contador de 500 ms
0000a2 9180 010c                     lds r24, halfsec_l
0000a4 9190 010d                     lds r25, halfsec_h
0000a6 9601                          adiw r24, 1                 ; Incremento de 16 bits
0000a7 9380 010c                     sts halfsec_l, r24
0000a9 9390 010d                     sts halfsec_h, r25
                                 
0000ab ef04                          ldi rA, low(500)
0000ac e011                          ldi rB, high(500)
0000ad 1780                          cp  r24, rA
0000ae 0791                          cpc r25, rB
0000af f459                          brne T0_SKIP_500            ; Aún no llegó a 500 -> saltar el toggle
                                 
                                     ; Resetear contador e invertir blink_flag
0000b0 2700                          clr rA
0000b1 9300 010c                     sts halfsec_l, rA
0000b3 9300 010d                     sts halfsec_h, rA
                                 
0000b5 9100 0109                     lds rA, blink_flag
0000b7 e011                          ldi rB, 1
0000b8 2701                          eor rA, rB                  ; Invertir bit 0
0000b9 9300 0109                     sts blink_flag, rA
                                 
                                 T0_SKIP_500:
                                     ;Contador de 1000 ms 
0000bb 9180 010a                     lds r24, ms_count_l
0000bd 9190 010b                     lds r25, ms_count_h
0000bf 9601                          adiw r24, 1
0000c0 9380 010a                     sts ms_count_l, r24
0000c2 9390 010b                     sts ms_count_h, r25
                                 
0000c4 ee08                          ldi rA, low(1000)
0000c5 e013                          ldi rB, high(1000)
0000c6 1780                          cp  r24, rA
0000c7 0791                          cpc r25, rB
0000c8 f431                          brne T0_SKIP_1S             ; Aún no llegó a 1000 -> saltar tick del reloj
                                 
                                     ; Resetear contador y avanzar el reloj
0000c9 2700                          clr rA
0000ca 9300 010a                     sts ms_count_l, rA
0000cc 9300 010b                     sts ms_count_h, rA
                                 
0000ce d186                          rcall CLOCK_TICK_1S         ; Incrementar segundos y verificar alarma
                                 
                                 T0_SKIP_1S:
0000cf d13e                          rcall MUX_REFRESH           ; Refrescar un dígito
                                 
                                     ; Restaurar todos los registros en orden inverso
0000d0 91ff                          pop r31
0000d1 91ef                          pop r30
0000d2 919f                          pop r25
0000d3 918f                          pop r24
0000d4 917f                          pop r23
0000d5 916f                          pop r22
0000d6 915f                          pop r21
0000d7 914f                          pop r20
0000d8 913f                          pop r19
0000d9 912f                          pop r18
0000da 911f                          pop r17
0000db 910f                          pop r16
0000dc bf0f                          out SREG, r16
0000dd 910f                          pop r16
0000de 9518                          reti
                                 
                                 ; ISR_PCINT1  - Interrupción por cambio de pin en PORTC
                                 ISR_PCINT1:
0000df 930f                          push r16
0000e0 b70f                          in   r16, SREG
0000e1 930f                          push r16
0000e2 931f                          push r17
0000e3 932f                          push r18
                                 
0000e4 b106                          in  rA, PINC            ; Leer estado actual de botones (0 = presionado)
0000e5 9110 0113                     lds rB, btn_locks       ; Sombra: qué botones estaban presionados antes
0000e7 9120 0114                     lds rC, btn_events      ; Eventos pendientes aún no consumidos por el bucle principal
                                 
                                     ;PC0 -> botón VIEW
0000e9 ff00                          sbrs rA, 0              ; Si bit 0 = 1, el pin está en HIGH - botón suelto
0000ea c005                          rjmp PC0_PRESSED
                                 PC0_RELEASED:
0000eb ff10                          sbrs rB, BTN_VIEW_BIT   ; żEstaba bloqueado? (żse registró la presión?)
0000ec c004                          rjmp CHECK_PC1
0000ed 7f1e                          cbr rB, (1<<BTN_VIEW_BIT)      ; Limpiar bloqueo
0000ee 6021                          sbr rC, (1<<BTN_VIEW_BIT)      ; Registrar evento de soltar
0000ef c001                          rjmp CHECK_PC1
                                 PC0_PRESSED:
0000f0 6011                          sbr rB, (1<<BTN_VIEW_BIT)      ; Marcar como mantenido presionado
                                 
                                 CHECK_PC1:
                                     ;PC1 - botón UP
0000f1 ff01                          sbrs rA, 1
0000f2 c005                          rjmp PC1_PRESSED
                                 PC1_RELEASED:
0000f3 ff11                          sbrs rB, BTN_UP_BIT
0000f4 c004                          rjmp CHECK_PC2
0000f5 7f1d                          cbr rB, (1<<BTN_UP_BIT)
0000f6 6022                          sbr rC, (1<<BTN_UP_BIT)
0000f7 c001                          rjmp CHECK_PC2
                                 PC1_PRESSED:
0000f8 6012                          sbr rB, (1<<BTN_UP_BIT)
                                 
                                 CHECK_PC2:
                                     ;PC2 - botón DOWN
0000f9 ff02                          sbrs rA, 2
0000fa c005                          rjmp PC2_PRESSED
                                 PC2_RELEASED:
0000fb ff12                          sbrs rB, BTN_DOWN_BIT
0000fc c004                          rjmp CHECK_PC3
0000fd 7f1b                          cbr rB, (1<<BTN_DOWN_BIT)
0000fe 6024                          sbr rC, (1<<BTN_DOWN_BIT)
0000ff c001                          rjmp CHECK_PC3
                                 PC2_PRESSED:
000100 6014                          sbr rB, (1<<BTN_DOWN_BIT)
                                 
                                 CHECK_PC3:
                                     ;PC3 - botón MODE
000101 ff03                          sbrs rA, 3
000102 c005                          rjmp PC3_PRESSED
                                 PC3_RELEASED:
000103 ff13                          sbrs rB, BTN_MODE_BIT
000104 c004                          rjmp ISR_PC1_END
000105 7f17                          cbr rB, (1<<BTN_MODE_BIT)
000106 6028                          sbr rC, (1<<BTN_MODE_BIT)
000107 c001                          rjmp ISR_PC1_END
                                 PC3_PRESSED:
000108 6018                          sbr rB, (1<<BTN_MODE_BIT)
                                 
                                 ISR_PC1_END:
000109 9310 0113                     sts btn_locks,  rB      ; Persistir estado de bloqueos actualizado
00010b 9320 0114                     sts btn_events, rC      ; Persistir flags de eventos actualizados
                                 
00010d 912f                          pop r18
00010e 911f                          pop r17
00010f 910f                          pop r16
000110 bf0f                          out SREG, r16
000111 910f                          pop r16
000112 9518                          reti
                                 
                                 ; PROCESS_BUTTON_EVENTS
                                 ; Cada evento manejado se limpia antes del despacho para que una ISR re-entrante no pierda el siguiente flanco.
                                 PROCESS_BUTTON_EVENTS:
000113 930f                          push r16
000114 931f                          push r17
000115 932f                          push r18
                                 
000116 9100 0114                     lds rA, btn_events
000118 2300                          tst rA
000119 f409                          brne PBE_GO
00011a c05e                          rjmp PBE_END            ;Sin eventos pendientes - retorno rápido
                                 PBE_GO:
                                 
                                     ; ---- Evento botón MODE --------------------------------------------------
00011b ff03                          sbrs rA, BTN_MODE_BIT
00011c c037                          rjmp PBE_CHECK_VIEW
                                 
00011d 7f07                          cbr rA, (1<<BTN_MODE_BIT)
00011e 9300 0114                     sts btn_events, rA      ; Limpiar evento inmediatamente
                                 
                                     ; Si la alarma está sonando, MODE la silencia
000120 9110 0115                     lds rB, alarm_ringing
000122 2311                          tst rB
000123 f021                          breq PBE_MODE_NEXT
000124 2711                          clr rB
000125 9310 0115                     sts alarm_ringing, rB
000127 c051                          rjmp PBE_END
                                 
                                 PBE_MODE_NEXT:
                                     ; Avanzar edit_mode, con vuelta de 6 -> 0
000128 9110 0108                     lds rB, edit_mode
00012a 9513                          inc rB
00012b 3017                          cpi rB, 7
00012c f008                          brlo PBE_MODE_OK
00012d 2711                          clr rB
                                 PBE_MODE_OK:
00012e 9310 0108                     sts edit_mode, rB
                                 
                                     ;Forzar la vista que corresponde al nuevo modo de edición
000130 3011                          cpi rB, MODE_SET_HOUR
000131 f421                          brne PBE_MODE_CHK1
000132 e020                          ldi rC, VIEW_TIME
000133 9320 0107                     sts current_view, rC
000135 c043                          rjmp PBE_END
                                 
                                 PBE_MODE_CHK1:
000136 3012                          cpi rB, MODE_SET_MIN
000137 f421                          brne PBE_MODE_CHK2
000138 e020                          ldi rC, VIEW_TIME
000139 9320 0107                     sts current_view, rC
00013b c03d                          rjmp PBE_END
                                 
                                 PBE_MODE_CHK2:
00013c 3013                          cpi rB, MODE_SET_DAY
00013d f421                          brne PBE_MODE_CHK3
00013e e021                          ldi rC, VIEW_DATE
00013f 9320 0107                     sts current_view, rC
000141 c037                          rjmp PBE_END
                                 
                                 PBE_MODE_CHK3:
000142 3014                          cpi rB, MODE_SET_MON
000143 f421                          brne PBE_MODE_CHK4
000144 e021                          ldi rC, VIEW_DATE
000145 9320 0107                     sts current_view, rC
000147 c031                          rjmp PBE_END
                                 
                                 PBE_MODE_CHK4:
000148 3015                          cpi rB, MODE_SET_AH
000149 f421                          brne PBE_MODE_CHK5
00014a e022                          ldi rC, VIEW_ALARM
00014b 9320 0107                     sts current_view, rC
00014d c02b                          rjmp PBE_END
                                 
                                 PBE_MODE_CHK5:
00014e 3016                          cpi rB, MODE_SET_AM
00014f f549                          brne PBE_END
000150 e022                          ldi rC, VIEW_ALARM
000151 9320 0107                     sts current_view, rC
000153 c025                          rjmp PBE_END
                                 
                                     ;Evento botón VIEW
                                     ;Solo funciona en modo normal
                                 PBE_CHECK_VIEW:
000154 9100 0114                     lds rA, btn_events
000156 ff00                          sbrs rA, BTN_VIEW_BIT
000157 c010                          rjmp PBE_CHECK_UP
                                 
000158 7f0e                          cbr rA, (1<<BTN_VIEW_BIT)
000159 9300 0114                     sts btn_events, rA
                                 
00015b 9110 0108                     lds rB, edit_mode
00015d 2311                          tst rB
00015e f4d1                          brne PBE_END            ;Ignorar VIEW mientras se está en modo edición
                                 
00015f 9110 0107                     lds rB, current_view
000161 9513                          inc rB
000162 3013                          cpi rB, 3
000163 f008                          brlo PBE_VIEW_OK
000164 2711                          clr rB                  ;Vuelta de VIEW_ALARM - VIEW_TIME
                                 PBE_VIEW_OK:
000165 9310 0107                     sts current_view, rB
000167 c011                          rjmp PBE_END
                                 
                                     ;Evento botón UP
                                 PBE_CHECK_UP:
000168 9100 0114                     lds rA, btn_events
00016a ff01                          sbrs rA, BTN_UP_BIT
00016b c005                          rjmp PBE_CHECK_DOWN
                                 
00016c 7f0d                          cbr rA, (1<<BTN_UP_BIT)
00016d 9300 0114                     sts btn_events, rA
00016f d138                          rcall INCREMENT_ACTIVE_FIELD
000170 c008                          rjmp PBE_END
                                 
                                     ;Evento botón DOWN
                                 PBE_CHECK_DOWN:
000171 9100 0114                     lds rA, btn_events
000173 ff02                          sbrs rA, BTN_DOWN_BIT
000174 c004                          rjmp PBE_END
                                 
000175 7f0b                          cbr rA, (1<<BTN_DOWN_BIT)
000176 9300 0114                     sts btn_events, rA
000178 d184                          rcall DECREMENT_ACTIVE_FIELD
                                 
                                 PBE_END:
000179 912f                          pop r18
00017a 911f                          pop r17
00017b 910f                          pop r16
00017c 9508                          ret
                                 
                                 ; UPDATE_UI_STATE
                                 ; Calcula los flags colon_on y aux_led que usa MUX_REFRESH
                                 UPDATE_UI_STATE:
00017d 930f                          push r16
00017e 931f                          push r17
                                 
                                     ; Determinar estado del colon
00017f 9100 0107                     lds rA, current_view
000181 3001                          cpi rA, VIEW_DATE
000182 f421                          brne UI_NOT_DATE
000183 e011                          ldi rB, 1               ; Vista fecha: colon permanentemente encendido
000184 9310 0117                     sts colon_on, rB
000186 c004                          rjmp UI_AUX
                                 
                                 UI_NOT_DATE:
000187 9110 0109                     lds rB, blink_flag      ; Otras vistas: colon parpadea a 1 Hz
000189 9310 0117                     sts colon_on, rB
                                 
                                 UI_AUX:
                                     ; Determinar estado del LED indicador de alarma
00018b 2711                          clr rB
                                 
00018c 9100 0107                     lds rA, current_view
00018e 3002                          cpi rA, VIEW_ALARM
00018f f039                          breq UI_AUX_ON          ; Viendo alarma - LED encendido
                                 
                                     ; También encendido al configurar los campos de alarma
000190 9100 0108                     lds rA, edit_mode
000192 3005                          cpi rA, MODE_SET_AH
000193 f019                          breq UI_AUX_ON
000194 3006                          cpi rA, MODE_SET_AM
000195 f009                          breq UI_AUX_ON
000196 c001                          rjmp UI_AUX_STORE
                                 
                                 UI_AUX_ON:
000197 e011                          ldi rB, 1
                                 
                                 UI_AUX_STORE:
000198 9310 0118                     sts aux_led, rB
                                 
00019a 911f                          pop r17
00019b 910f                          pop r16
00019c 9508                          ret
                                 
                                 ; BUILD_DISPLAY_BUFFER
                                 ; Determina qué par de dígitos mostrar según current_view, separa cada valor en decenas/unidades, aplica el blanco de parpadeo para el campo en edición, y convierte cada dígito a su patrón de segmento.
                                 BUILD_DISPLAY_BUFFER:
00019d 930f                          push r16
00019e 931f                          push r17
00019f 932f                          push r18
0001a0 933f                          push r19
0001a1 934f                          push r20
0001a2 935f                          push r21
0001a3 936f                          push r22
0001a4 937f                          push r23
0001a5 938f                          push r24
0001a6 939f                          push r25
0001a7 93ef                          push r30
0001a8 93ff                          push r31
                                 
                                     ;Seleccionar fuente de datos según la vista
0001a9 9100 0107                     lds rA, current_view
0001ab 3000                          cpi rA, VIEW_TIME
0001ac f429                          brne BDB_CHK_DATE
0001ad 9110 0100                     lds rB, hour            ; Mostrar HH:MM
0001af 9120 0101                     lds rC, minute
0001b1 c00b                          rjmp BDB_SPLIT_PAIR
                                 
                                 BDB_CHK_DATE:
0001b2 3001                          cpi rA, VIEW_DATE
0001b3 f429                          brne BDB_ALARM
0001b4 9110 0103                     lds rB, day             ; Mostrar DD:MM
0001b6 9120 0104                     lds rC, month
0001b8 c004                          rjmp BDB_SPLIT_PAIR
                                 
                                 BDB_ALARM:
0001b9 9110 0105                     lds rB, alarm_hour      ; Mostrar alarma HH:MM
0001bb 9120 0106                     lds rC, alarm_min
                                 
                                 BDB_SPLIT_PAIR:
                                     ; Separar valor izquierdo en decenas (r18) y unidades (r19)
0001bd 2f81                          mov r24, rB
0001be d03b                          rcall SPLIT_DECIMAL
0001bf 2f28                          mov r18, r24            ; Dígito de decenas
0001c0 2f39                          mov r19, r25            ; Dígito de unidades
                                 
                                     ; Separar valor derecho en decenas (r20) y unidades (r21)
0001c1 2f82                          mov r24, rC
0001c2 d037                          rcall SPLIT_DECIMAL
0001c3 2f48                          mov r20, r24            ; Dígito de decenas
0001c4 2f59                          mov r21, r25            ; Dígito de unidades
                                 
                                     ; Lógica de parpadeo
                                     ; Cuando blink_flag == 0, blanquear el campo en edición.
0001c5 9100 0109                     lds rA, blink_flag
0001c7 2300                          tst rA
0001c8 f4a1                          brne BDB_CONVERT        ; mostrar todos los dígitos normalmente
                                 
0001c9 9100 0108                     lds rA, edit_mode
0001cb 3001                          cpi rA, MODE_SET_HOUR
0001cc f059                          breq BDB_BLANK_LEFT
0001cd 3003                          cpi rA, MODE_SET_DAY
0001ce f049                          breq BDB_BLANK_LEFT
0001cf 3005                          cpi rA, MODE_SET_AH
0001d0 f039                          breq BDB_BLANK_LEFT
0001d1 3002                          cpi rA, MODE_SET_MIN
0001d2 f041                          breq BDB_BLANK_RIGHT
0001d3 3004                          cpi rA, MODE_SET_MON
0001d4 f031                          breq BDB_BLANK_RIGHT
0001d5 3006                          cpi rA, MODE_SET_AM
0001d6 f021                          breq BDB_BLANK_RIGHT
0001d7 c005                          rjmp BDB_CONVERT        ; MODE_NORMAL
                                 
                                 BDB_BLANK_LEFT:
                                     ; Reemplazar dígitos del par izquierdo con BLANK_CODE
0001d8 e02a                          ldi r18, BLANK_CODE
0001d9 e03a                          ldi r19, BLANK_CODE
0001da c002                          rjmp BDB_CONVERT
                                 
                                 BDB_BLANK_RIGHT:
0001db e04a                          ldi r20, BLANK_CODE
0001dc e05a                          ldi r21, BLANK_CODE
                                 
                                 BDB_CONVERT:
                                     ; Convertir cada índice de dígito al patrón de segmento de hardware
0001dd 2f82                          mov r24, r18
0001de d025                          rcall DIGIT_TO_SEG
0001df 9380 010f                     sts disp0, r24
                                 
0001e1 2f83                          mov r24, r19
0001e2 d021                          rcall DIGIT_TO_SEG
0001e3 9380 0110                     sts disp1, r24
                                 
0001e5 2f84                          mov r24, r20
0001e6 d01d                          rcall DIGIT_TO_SEG
0001e7 9380 0111                     sts disp2, r24
                                 
0001e9 2f85                          mov r24, r21
0001ea d019                          rcall DIGIT_TO_SEG
0001eb 9380 0112                     sts disp3, r24
                                 
0001ed 91ff                          pop r31
0001ee 91ef                          pop r30
0001ef 919f                          pop r25
0001f0 918f                          pop r24
0001f1 917f                          pop r23
0001f2 916f                          pop r22
0001f3 915f                          pop r21
0001f4 914f                          pop r20
0001f5 913f                          pop r19
0001f6 912f                          pop r18
0001f7 911f                          pop r17
0001f8 910f                          pop r16
0001f9 9508                          ret
                                 
                                 ; SPLIT_DECIMAL
                                 
                                 ; Algoritmo: resta repetida de 10.
                                 SPLIT_DECIMAL:
0001fa 2799                          clr r25
0001fb 2700                          clr rA              ; Acumula el conteo de decenas
                                 SPLIT_LOOP:
0001fc 308a                          cpi r24, 10
0001fd f018                          brlo SPLIT_DONE     ; r24 < 10 - el residuo es el dígito de unidades
0001fe 508a                          subi r24, 10
0001ff 9503                          inc rA
000200 cffb                          rjmp SPLIT_LOOP
                                 SPLIT_DONE:
000201 2f98                          mov r25, r24        ; Residuo - unidades
000202 2f80                          mov r24, rA         ; Conteo  - decenas
000203 9508                          ret
                                 
                                 ; DIGIT_TO_SEG
                                 ; Usa el registro Z (ZH:ZL) como puntero a memoria de programa.
                                 DIGIT_TO_SEG:
000204 93ff                          push ZH
000205 93ef                          push ZL
000206 e0f0                          ldi ZH, high(SEG_TABLE<<1)
000207 e6e6                          ldi ZL, low(SEG_TABLE<<1)
000208 0fe8                          add ZL, r24             ; Desplazamiento al dígito solicitado
000209 1df1                          adc ZH, r1              ; Acarreo al byte alto
00020a 9184                          lpm r24, Z              ; Cargar byte desde la flash
00020b 91ef                          pop ZL
00020c 91ff                          pop ZH
00020d 9508                          ret
                                 
                                 ; MUX_REFRESH
                                 ; Llamado cada 1 ms desde ISR_TIMER0_COMPA.
                                 ; Maneja un dígito por llamada, ciclando scan_idx 0->1->2->3->0...
                                 MUX_REFRESH:
00020e 930f                          push r16
00020f 931f                          push r17
000210 932f                          push r18
000211 933f                          push r19
000212 934f                          push r20
                                 
000213 9100 010e                     lds rA, scan_idx
                                 
                                     ; Seleccionar datos de segmento y pin de selección para la ranura actual
000215 3000                          cpi rA, 0
000216 f421                          brne MUX_CHK1
000217 9110 010f                     lds rB, disp0
000219 e220                          ldi rC, (1<<PD5)        ; Dígito 0 en PD5
00021a c00f                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK1:
00021b 3001                          cpi rA, 1
00021c f421                          brne MUX_CHK2
00021d 9110 0110                     lds rB, disp1
00021f e120                          ldi rC, (1<<PD4)        ; Dígito 1 en PD4
000220 c009                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK2:
000221 3002                          cpi rA, 2
000222 f421                          brne MUX_CHK3
000223 9110 0111                     lds rB, disp2
000225 e028                          ldi rC, (1<<PD3)        ; Dígito 2 en PD3
000226 c003                          rjmp MUX_OUTPUT
                                 
                                 MUX_CHK3:
000227 9110 0112                     lds rB, disp3
000229 e024                          ldi rC, (1<<PD2)        ; Dígito 3 en PD2
                                 
                                 MUX_OUTPUT:
00022a 2f31                          mov rD, rB
00022b 9536                          lsr rD
00022c 9536                          lsr rD
00022d 713f                          andi rD, 0b00011111
                                 
00022e 9140 0117                     lds rE, colon_on
000230 2344                          tst rE
000231 f009                          breq MUX_NO_COLON
000232 6230                          ori rD, (1<<PB5)        ; Activar bit del LED colon
                                 MUX_NO_COLON:
000233 b935                          out PORTB, rD
                                 
                                     ; PORTD: segmentos F y G  + selección de dígito 
000234 2733                          clr rD
000235 fd11                          sbrc rB, 1              ; Bit 1 del byte de segmento = seg F
000236 6830                          ori rD, (1<<PD7)
000237 fd10                          sbrc rB, 0              ; Bit 0 del byte de segmento = seg G
000238 6430                          ori rD, (1<<PD6)
000239 2b32                          or   rD, rC             ; OR con el bit de selección de dígito
00023a b93b                          out PORTD, rD
                                 
                                     ; PORTC: mantener pull-ups, manejar LED y buzzer
00023b e03f                          ldi rD, 0b00001111      ; Base: pull-ups en PC0-PC3, salidas en bajo
                                 
00023c 9140 0118                     lds rE, aux_led
00023e 2344                          tst rE
00023f f009                          breq MUX_NO_AUX
000240 6130                          ori rD, (1<<PC4)        ; Encender LED indicador de alarma
                                 MUX_NO_AUX:
                                 
000241 9140 0115                     lds rE, alarm_ringing
000243 2344                          tst rE
000244 f009                          breq MUX_NO_BUZZ
000245 6230                          ori rD, (1<<PC5)        ; Activar buzzer
                                 MUX_NO_BUZZ:
000246 b938                          out PORTC, rD
                                 
                                     ; Avanzar índice de escaneo, vuelta en 4 
000247 9100 010e                     lds rA, scan_idx
000249 9503                          inc rA
00024a 3004                          cpi rA, 4
00024b f008                          brlo MUX_STORE
00024c 2700                          clr rA
                                 MUX_STORE:
00024d 9300 010e                     sts scan_idx, rA
                                 
00024f 914f                          pop r20
000250 913f                          pop r19
000251 912f                          pop r18
000252 911f                          pop r17
000253 910f                          pop r16
000254 9508                          ret
                                 
                                 ; CLOCK_TICK_1S
                                 ; Llamado una vez por segundo desde ISR_TIMER0_COMPA.
                                 CLOCK_TICK_1S:
000255 930f                          push r16
000256 931f                          push r17
000257 932f                          push r18
                                 
                                     ; Segundos: 0..59 
000258 9100 0102                     lds rA, second
00025a 9503                          inc rA
00025b 330c                          cpi rA, 60
00025c f0d8                          brlo CT_STORE_SEC       ; Aún no es 60: guardar y saltar a verificación de alarma
                                 
                                     ; Segundo desbordado - incrementar minutos
00025d 2700                          clr rA
00025e 9300 0102                     sts second, rA
                                 
000260 9100 0101                     lds rA, minute
000262 9503                          inc rA
000263 330c                          cpi rA, 60
000264 f080                          brlo CT_STORE_MIN
                                 
                                     ; Minuto desbordado - incrementar horas
000265 2700                          clr rA
000266 9300 0101                     sts minute, rA
                                 
000268 9100 0100                     lds rA, hour
00026a 9503                          inc rA
00026b 3108                          cpi rA, 24
00026c f028                          brlo CT_STORE_HOUR
                                 
                                     ; Hora desbordada - incrementar día
00026d 2700                          clr rA
00026e 9300 0100                     sts hour, rA
000270 d0e6                          rcall INCREMENT_DAY_ROLLOVER
000271 c008                          rjmp CT_ALARM_CHECK
                                 
                                 CT_STORE_HOUR:
000272 9300 0100                     sts hour, rA
000274 c005                          rjmp CT_ALARM_CHECK
                                 
                                 CT_STORE_MIN:
000275 9300 0101                     sts minute, rA
000277 c002                          rjmp CT_ALARM_CHECK
                                 
                                 CT_STORE_SEC:
000278 9300 0102                     sts second, rA
                                 
                                 CT_ALARM_CHECK:
                                     ; Evaluar solo en el segundo 0
00027a 9100 0102                     lds rA, second
00027c 2300                          tst rA
00027d f4b1                          brne CT_CLEAR_IF_NEEDED ; No es segundo 0: verificar si hay que limpiar el latch
                                 
                                     ; Verificar coincidencia de hora
00027e 9100 0100                     lds rA, hour
000280 9110 0105                     lds rB, alarm_hour
000282 1701                          cp  rA, rB
000283 f481                          brne CT_CLEAR_IF_NEEDED ; Hora no coincide: limpiar latch si está lejos de la alarma
                                 
                                     ; Verificar coincidencia de minuto
000284 9100 0101                     lds rA, minute
000286 9110 0106                     lds rB, alarm_min
000288 1701                          cp  rA, rB
000289 f451                          brne CT_CLEAR_IF_NEEDED
                                 
                                     ; Hora y minuto coinciden en segundo 0: activar alarma si no está latcheada
00028a 9100 0116                     lds rA, alarm_latched
00028c 2300                          tst rA
00028d f4b1                          brne CT_END             ; Ya se activó este minuto: no hacer nada
                                 
00028e e001                          ldi rA, 1
00028f 9300 0115                     sts alarm_ringing, rA   ; Comenzar a sonar
000291 9300 0116                     sts alarm_latched, rA   ; Activar latch para evitar re-activación
000293 c010                          rjmp CT_END
                                 
                                 CT_CLEAR_IF_NEEDED:
                                     ; Se llega aquí cuando la hora no coincide con alarm_hour:alarm_min. Antes de limpiar el latch, confirmar que realmente estamos lejos del match
000294 9100 0100                     lds rA, hour
000296 9110 0105                     lds rB, alarm_hour
000298 1701                          cp  rA, rB
000299 f439                          brne CT_CLEAR_LATCH     ; Hora diferente - definitivamente lejos de la alarma
                                 
00029a 9100 0101                     lds rA, minute
00029c 9110 0106                     lds rB, alarm_min
00029e 1701                          cp  rA, rB
00029f f409                          brne CT_CLEAR_LATCH     ; Minuto diferente - definitivamente lejos de la alarma
                                 
0002a0 c003                          rjmp CT_END             ; Mismo HH:MM pero second!=0 dejar el latch intacto
                                 
                                 CT_CLEAR_LATCH:
0002a1 2700                          clr rA
0002a2 9300 0116                     sts alarm_latched, rA   ; Dejar que la alarma se active en la próxima coincidencia
                                 
                                 CT_END:
0002a4 912f                          pop r18
0002a5 911f                          pop r17
0002a6 910f                          pop r16
0002a7 9508                          ret
                                 
                                 ; INCREMENT_ACTIVE_FIELD
                                 ; Incrementa el campo de reloj/calendario/alarma que corresponde al edit_mode actual. Envuelve cada campo dentro de su rango válido.
                                 INCREMENT_ACTIVE_FIELD:
0002a8 930f                          push r16
0002a9 931f                          push r17
                                 
0002aa 9100 0108                     lds rA, edit_mode
                                 
                                     ; Incrementar hora
0002ac 3001                          cpi rA, MODE_SET_HOUR
0002ad f449                          brne IAF_CHK_MIN
0002ae 9110 0100                     lds rB, hour
0002b0 9513                          inc rB
0002b1 3118                          cpi rB, 24
0002b2 f008                          brlo IAF_H_OK
0002b3 2711                          clr rB                  ; Vuelta de 24 - 0
                                 IAF_H_OK:
0002b4 9310 0100                     sts hour, rB
0002b6 c043                          rjmp IAF_END
                                 
                                     ; Incrementar minuto
                                 IAF_CHK_MIN:
0002b7 3002                          cpi rA, MODE_SET_MIN
0002b8 f461                          brne IAF_CHK_DAY
0002b9 9110 0101                     lds rB, minute
0002bb 9513                          inc rB
0002bc 331c                          cpi rB, 60
0002bd f008                          brlo IAF_M_OK
0002be 2711                          clr rB
                                 IAF_M_OK:
0002bf 9310 0101                     sts minute, rB
0002c1 2711                          clr rB
0002c2 9310 0102                     sts second, rB          ; Resetear segundos para ajuste limpio de hora
0002c4 c035                          rjmp IAF_END
                                 
                                     ; Incrementar día
                                 IAF_CHK_DAY:
0002c5 3003                          cpi rA, MODE_SET_DAY
0002c6 f459                          brne IAF_CHK_MON
0002c7 9110 0103                     lds rB, day
0002c9 9513                          inc rB
0002ca d0a6                          rcall GET_MONTH_MAXDAY  ; Devuelve máximo de días en rC
0002cb 1712                          cp  rB, rC
0002cc f010                          brlo IAF_D_OK
0002cd f009                          breq IAF_D_OK           ; Permitir día == máximo
0002ce e011                          ldi rB, 1               ; Vuelta al superar el máximo - día 1
                                 IAF_D_OK:
0002cf 9310 0103                     sts day, rB
0002d1 c028                          rjmp IAF_END
                                 
                                     ; Incrementar mes (1..12) y ajustar día si es necesario
                                 IAF_CHK_MON:
0002d2 3004                          cpi rA, MODE_SET_MON
0002d3 f489                          brne IAF_CHK_AH
0002d4 9110 0104                     lds rB, month
0002d6 9513                          inc rB
0002d7 301d                          cpi rB, 13
0002d8 f008                          brlo IAF_MON_OK
0002d9 e011                          ldi rB, 1               ; Vuelta de diciembre - enero
                                 IAF_MON_OK:
0002da 9310 0104                     sts month, rB
0002dc 9110 0103                     lds rB, day
0002de d092                          rcall GET_MONTH_MAXDAY
0002df 1712                          cp  rB, rC
0002e0 f0c8                          brlo IAF_END
0002e1 f0c1                          breq IAF_END
0002e2 9320 0103                     sts day, rC             ; Limitar día al máximo del nuevo mes
0002e4 c015                          rjmp IAF_END
                                 
                                     ; Incrementar hora de alarma
                                 IAF_CHK_AH:
0002e5 3005                          cpi rA, MODE_SET_AH
0002e6 f449                          brne IAF_CHK_AM
0002e7 9110 0105                     lds rB, alarm_hour
0002e9 9513                          inc rB
0002ea 3118                          cpi rB, 24
0002eb f008                          brlo IAF_AH_OK
0002ec 2711                          clr rB
                                 IAF_AH_OK:
0002ed 9310 0105                     sts alarm_hour, rB
0002ef c00a                          rjmp IAF_END
                                 
                                     ; Incrementar minuto de alarma
                                 IAF_CHK_AM:
0002f0 3006                          cpi rA, MODE_SET_AM
0002f1 f441                          brne IAF_END
0002f2 9110 0106                     lds rB, alarm_min
0002f4 9513                          inc rB
0002f5 331c                          cpi rB, 60
0002f6 f008                          brlo IAF_AM_OK
0002f7 2711                          clr rB
                                 IAF_AM_OK:
0002f8 9310 0106                     sts alarm_min, rB
                                 
                                 IAF_END:
0002fa 911f                          pop r17
0002fb 910f                          pop r16
0002fc 9508                          ret
                                 
                                 ; DECREMENT_ACTIVE_FIELD
                                 ; Espejo de INCREMENT_ACTIVE_FIELD, decrementando cada campo con vuelta circular, los valores por debajo del mínimo vuelven al máximo del campo.
                                 DECREMENT_ACTIVE_FIELD:
0002fd 930f                          push r16
0002fe 931f                          push r17
                                 
0002ff 9100 0108                     lds rA, edit_mode
                                 
                                     ; Decrementar hora
000301 3001                          cpi rA, MODE_SET_HOUR
000302 f451                          brne DAF_CHK_MIN
000303 9110 0100                     lds rB, hour
000305 2311                          tst rB
000306 f411                          brne DAF_H_DEC
000307 e117                          ldi rB, 23              ; Vuelta de 0 - 23
000308 c001                          rjmp DAF_H_STORE
                                 DAF_H_DEC:
000309 951a                          dec rB
                                 DAF_H_STORE:
00030a 9310 0100                     sts hour, rB
00030c c047                          rjmp DAF_END
                                 
                                     ; Decrementar minuto
                                 DAF_CHK_MIN:
00030d 3002                          cpi rA, MODE_SET_MIN
00030e f469                          brne DAF_CHK_DAY
00030f 9110 0101                     lds rB, minute
000311 2311                          tst rB
000312 f411                          brne DAF_M_DEC
000313 e31b                          ldi rB, 59
000314 c001                          rjmp DAF_M_STORE
                                 DAF_M_DEC:
000315 951a                          dec rB
                                 DAF_M_STORE:
000316 9310 0101                     sts minute, rB
000318 2711                          clr rB
000319 9310 0102                     sts second, rB          ; Resetear segundos al cambiar el minuto
00031b c038                          rjmp DAF_END
                                 
                                     ; Decrementar día, vuelta al último día del mes actual
                                 DAF_CHK_DAY:
00031c 3003                          cpi rA, MODE_SET_DAY
00031d f459                          brne DAF_CHK_MON
00031e 9110 0103                     lds rB, day
000320 3011                          cpi rB, 1
000321 f419                          brne DAF_D_DEC
000322 d04e                          rcall GET_MONTH_MAXDAY  ; Vuelta de 1 - último día del mes
000323 2f12                          mov rB, rC
000324 c001                          rjmp DAF_D_STORE
                                 DAF_D_DEC:
000325 951a                          dec rB
                                 DAF_D_STORE:
000326 9310 0103                     sts day, rB
000328 c02b                          rjmp DAF_END
                                 
                                     ; Decrementar mes (1..12), ajustar día si es necesario
                                 DAF_CHK_MON:
000329 3004                          cpi rA, MODE_SET_MON
00032a f491                          brne DAF_CHK_AH
00032b 9110 0104                     lds rB, month
00032d 3011                          cpi rB, 1
00032e f411                          brne DAF_MON_DEC
00032f e01c                          ldi rB, 12              ; Vuelta de enero - diciembre
000330 c001                          rjmp DAF_MON_STORE
                                 DAF_MON_DEC:
000331 951a                          dec rB
                                 DAF_MON_STORE:
000332 9310 0104                     sts month, rB
000334 9110 0103                     lds rB, day
000336 d03a                          rcall GET_MONTH_MAXDAY
000337 1712                          cp  rB, rC
000338 f0d8                          brlo DAF_END
000339 f0d1                          breq DAF_END
00033a 9320 0103                     sts day, rC             ; Limitar día al máximo del nuevo mes
00033c c017                          rjmp DAF_END
                                 
                                     ; Decrementar hora de alarma
                                 DAF_CHK_AH:
00033d 3005                          cpi rA, MODE_SET_AH
00033e f451                          brne DAF_CHK_AM
00033f 9110 0105                     lds rB, alarm_hour
000341 2311                          tst rB
000342 f411                          brne DAF_AH_DEC
000343 e117                          ldi rB, 23
000344 c001                          rjmp DAF_AH_STORE
                                 DAF_AH_DEC:
000345 951a                          dec rB
                                 DAF_AH_STORE:
000346 9310 0105                     sts alarm_hour, rB
000348 c00b                          rjmp DAF_END
                                 
                                     ; Decrementar minuto de alarma
                                 DAF_CHK_AM:
000349 3006                          cpi rA, MODE_SET_AM
00034a f449                          brne DAF_END
00034b 9110 0106                     lds rB, alarm_min
00034d 2311                          tst rB
00034e f411                          brne DAF_AM_DEC
00034f e31b                          ldi rB, 59
000350 c001                          rjmp DAF_AM_STORE
                                 DAF_AM_DEC:
000351 951a                          dec rB
                                 DAF_AM_STORE:
000352 9310 0106                     sts alarm_min, rB
                                 
                                 DAF_END:
000354 911f                          pop r17
000355 910f                          pop r16
000356 9508                          ret
                                 
                                 ; INCREMENT_DAY_ROLLOVER
                                 ; Llamado por CLOCK_TICK_1S al desbordarse la medianoche.
                                 ; Avanza el día del calendario, pasando al día 1 del mes siguiente
                                 INCREMENT_DAY_ROLLOVER:
000357 930f                          push r16
000358 931f                          push r17
                                 
000359 9100 0103                     lds rA, day
00035b 9503                          inc rA
                                 
00035c d014                          rcall GET_MONTH_MAXDAY  ; Devuelve máximo de días en rC
00035d 1702                          cp  rA, rC
00035e f068                          brlo IDR_STORE
00035f f061                          breq IDR_STORE          ; día == máximo sigue siendo válido
                                 
                                     ; El día superó el máximo del mes: pasar al día 1 del mes siguiente
000360 e001                          ldi rA, 1
000361 9300 0103                     sts day, rA
                                 
000363 9110 0104                     lds rB, month
000365 9513                          inc rB
000366 301d                          cpi rB, 13
000367 f008                          brlo IDR_MON_OK
000368 e011                          ldi rB, 1               ; Diciembre - Enero
                                 IDR_MON_OK:
000369 9310 0104                     sts month, rB
00036b c002                          rjmp IDR_END
                                 
                                 IDR_STORE:
00036c 9300 0103                     sts day, rA
                                 
                                 IDR_END:
00036e 911f                          pop r17
00036f 910f                          pop r16
000370 9508                          ret
                                 
                                 ; GET_MONTH_MAXDAY
                                 ; Devuelve la cantidad de días del mes actual en el registro rC. Lee la variable 'month' de la SRAM directamente.
                                 GET_MONTH_MAXDAY:
000371 930f                          push r16
                                 
000372 9100 0104                     lds rA, month
                                 
000374 3002                          cpi rA, 2
000375 f051                          breq GMD_FEB            ; Febrero - 28 días
                                 
                                     ; Meses con 30 días
000376 3004                          cpi rA, 4
000377 f051                          breq GMD_30
000378 3006                          cpi rA, 6
000379 f041                          breq GMD_30
00037a 3009                          cpi rA, 9
00037b f031                          breq GMD_30
00037c 300b                          cpi rA, 11
00037d f021                          breq GMD_30
                                 
                                     ; Todos los meses restantes - 31 días
00037e e12f                          ldi rC, 31
00037f c003                          rjmp GMD_END
                                 
                                 GMD_FEB:
000380 e12c                          ldi rC, 28
000381 c001                          rjmp GMD_END
                                 
                                 GMD_30:
000382 e12e                          ldi rC, 30
                                 
                                 GMD_END:
000383 910f                          pop r16


